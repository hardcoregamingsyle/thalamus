  if (!jsonMatch) return null;
  try {
    const raw = jsonMatch[1] ?? jsonMatch[0];
    const parsed = JSON.parse(raw) as PlannerOutput;
    if (!Array.isArray(parsed.tasks)) return null;
    return parsed;
  } catch {
    return null;
  }
}

