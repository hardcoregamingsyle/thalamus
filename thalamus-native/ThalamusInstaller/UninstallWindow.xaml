<Window x:Class="ThalamusInstaller.UninstallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Uninstall Thalamus AI"
        Width="520" Height="460"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="{StaticResource BgDarkerBrush}"
        FontFamily="{StaticResource AppFontFamily}"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <!-- Palette + PrimaryBtn/GhostBtn/DangerBtn/ThemedCheck come from the
         shared Styles/Theme.xaml (linked from ThalamusApp). -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ TITLE BAR ═══ -->
        <Border Grid.Row="0" Background="{StaticResource BgDarkerBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_Drag">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                    <Border Width="18" Height="18" CornerRadius="5" Margin="0,0,8,0"
                            Background="{StaticResource BlueGradient}">
                        <TextBlock Text="T" FontSize="10" FontWeight="Black" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Uninstall Thalamus AI" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" Width="46" Height="38"
                        FontSize="13" Click="CloseBtn_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background"      Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground"      Value="{StaticResource TextSecondaryBrush}"/>
                            <Setter Property="Cursor"          Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{StaticResource RedBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- ═══ PAGES ═══ -->
        <Grid Grid.Row="1">

            <!-- PAGE: Confirm -->
            <Grid x:Name="PageConfirm" Visibility="Visible">
                <StackPanel Margin="36,30,36,0" VerticalAlignment="Top">
                    <TextBlock Text="Remove Thalamus AI?" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap" FontSize="12.5" LineHeight="20"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,18">
                        This removes the app, its shortcuts, and its Windows registry
                        entries. Any running Thalamus windows will be closed.
                    </TextBlock>

                    <Border Background="{StaticResource BgCardBrush}" CornerRadius="10"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            Padding="16,12" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Will be removed:" FontSize="11.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock x:Name="InstallPathLabel" Text="" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="Desktop and Start Menu shortcuts" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                            <TextBlock Text="Registry entries (uninstall info, thalamus:// scheme, bridge autostart)"
                                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <CheckBox x:Name="ChkData" Style="{StaticResource ThemedCheck}"
                              Content="Also delete VM data (virtual machine disks and downloaded ISOs)"/>
                    <TextBlock Text="Leave this unchecked to keep your VMs for a future reinstall."
                               FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                               Margin="25,0,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Bottom" Margin="0,0,36,26">
                    <Button Content="Cancel" Style="{StaticResource GhostBtn}"
                            Width="110" Height="40" Margin="0,0,12,0" Click="CloseBtn_Click"/>
                    <Button x:Name="UninstallBtn" Content="Uninstall" Style="{StaticResource DangerBtn}"
                            Width="140" Click="Uninstall_Click"/>
                </StackPanel>
            </Grid>

            <!-- PAGE: Working -->
            <Grid x:Name="PageWorking" Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="360">
                    <TextBlock Text="Uninstalling…" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock x:Name="WorkingLabel" Text="Stopping Thalamus…" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- PAGE: Done -->
            <Grid x:Name="PageDone" Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="380">
                    <Border Width="60" Height="60" CornerRadius="16" HorizontalAlignment="Center"
                            Margin="0,0,0,18" Background="{StaticResource GreenBrush}">
                        <TextBlock Text="✓" FontSize="28" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Thalamus AI has been removed" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock x:Name="DoneDetail" Text="" FontSize="11.5"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               TextWrapping="Wrap" Margin="0,0,0,24"/>
                    <Button Content="Close" Style="{StaticResource PrimaryBtn}"
                            Width="140" HorizontalAlignment="Center" Click="Finish_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
