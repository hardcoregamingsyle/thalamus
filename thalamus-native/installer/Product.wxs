<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Product Id="*"
             Name="Thalamus AI"
             Language="1033"
             Version="1.0.0"
             Manufacturer="Thalamus AI"
             UpgradeCode="7A4C9F82-1E3B-4F6D-8C0A-5B2D7E9F1A3C">

        <Package InstallerVersion="200"
                 Compressed="yes"
                 InstallScope="perMachine"
                 Platform="x64" />

        <MajorUpgrade DowngradeErrorMessage="A newer version of Thalamus AI is already installed."
                      AllowSameVersionUpgrades="yes"
                      Schedule="afterInstallValidate" />

        <MediaTemplate EmbedCab="yes" />

        <!-- ── Directory Structure ────────────────────────────────────── -->
        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="ProgramFiles64Folder">
                <Directory Id="MANUFACTURERDIR" Name="Thalamus AI">
                    <Directory Id="INSTALLDIR" Name="Thalamus AI">

                        <!-- App files -->
                        <Component Id="AppExecutable" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
                            <File Id="ThalamusExe"
                                  Name="Thalamus.exe"
                                  Source="$(var.SourceDir)\Thalamus.exe"
                                  KeyPath="yes"
                                  Vital="yes" />

                            <Shortcut Id="StartMenuShortcut"
                                      Directory="ProgramMenuDir"
                                      Name="Thalamus AI"
                                      WorkingDirectory="INSTALLDIR"
                                      Icon="ThalamusIcon.exe"
                                      Advertise="yes" />

                            <Shortcut Id="DesktopShortcut"
                                      Directory="DesktopFolder"
                                      Name="Thalamus AI"
                                      WorkingDirectory="INSTALLDIR"
                                      Icon="ThalamusIcon.exe"
                                      Advertise="yes" />
                        </Component>

                        <!-- VM Bridge -->
                        <Component Id="VMBridge" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
                            <File Id="VMBridgeExe"
                                  Name="thalamus-vm-bridge.exe"
                                  Source="$(var.SourceDir)\thalamus-vm-bridge.exe"
                                  Vital="yes" />
                        </Component>

                        <!-- VM Bridge auto-start -->
                        <Component Id="VMBridgeAutoStart" Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
                            <RegistryValue Root="HKCU"
                                           Key="Software\Microsoft\Windows\CurrentVersion\Run"
                                           Name="ThalamusVMBridge"
                                           Value="[INSTALLDIR]thalamus-vm-bridge.exe"
                                           Type="string" />
                        </Component>

                        <!-- Data directory for VM disk images -->
                        <Directory Id="DataDir" Name="data">
                            <Component Id="DataDirComponent" Guid="D4E5F6A7-B8C9-0123-DEF1-234567890123">
                                <CreateFolder />
                            </Component>
                        </Directory>
                    </Directory>
                </Directory>
            </Directory>

            <!-- Start Menu -->
            <Directory Id="ProgramMenuFolder">
                <Directory Id="ProgramMenuDir" Name="Thalamus AI">
                    <Component Id="ProgramMenuDirComponent" Guid="E5F6A7B8-C9D0-1234-EF12-345678901234">
                        <RemoveFolder Id="ProgramMenuDir" On="uninstall" />
                        <RegistryValue Root="HKCU"
                                       Key="Software\[Manufacturer]\[ProductName]"
                                       Name="installed"
                                       Type="integer"
                                       Value="1" />
                    </Component>
                </Directory>
            </Directory>

            <!-- Desktop -->
            <Directory Id="DesktopFolder" Name="Desktop" />
        </Directory>

        <!-- ── Features ──────────────────────────────────────────────── -->
        <Feature Id="ProductFeature"
                 Title="Thalamus AI"
                 Level="1"
                 ConfigurableDirectory="INSTALLDIR">

            <ComponentRef Id="AppExecutable" />
            <ComponentRef Id="VMBridge" />
            <ComponentRef Id="VMBridgeAutoStart" />
            <ComponentRef Id="DataDirComponent" />
            <ComponentRef Id="ProgramMenuDirComponent" />
        </Feature>

        <!-- ── URI Scheme Registration ───────────────────────────────── -->
        <CustomAction Id="RegisterUriScheme"
                      Directory="INSTALLDIR"
                      Execute="deferred"
                      Impersonate="no"
                      Return="check"
                      ExeCommand="[SystemFolder]reg.exe add HKCR\thalamus /ve /d &quot;URL:Thalamus AI Protocol&quot; /f" />

        <CustomAction Id="RegisterUriSchemeCommand"
                      Directory="INSTALLDIR"
                      Execute="deferred"
                      Impersonate="no"
                      Return="check"
                      ExeCommand="[SystemFolder]reg.exe add HKCR\thalamus\shell\open\command /ve /d &quot;\&quot;[INSTALLDIR]Thalamus.exe\&quot; \&quot;%1\&quot;&quot; /f" />

        <CustomAction Id="RegisterUrlProtocol"
                      Directory="INSTALLDIR"
                      Execute="deferred"
                      Impersonate="no"
                      Return="check"
                      ExeCommand="[SystemFolder]reg.exe add HKCR\thalamus /v &quot;URL Protocol&quot; /d &quot;&quot; /f" />

        <InstallExecuteSequence>
            <Custom Action="RegisterUriScheme" After="InstallFiles" />
            <Custom Action="RegisterUrlProtocol" After="RegisterUriScheme" />
            <Custom Action="RegisterUriSchemeCommand" After="RegisterUrlProtocol" />
        </InstallExecuteSequence>

        <!-- ── UI ─────────────────────────────────────────────────────── -->
        <UIRef Id="WixUI_Minimal" />

        <WixVariable Id="WixUILicenseRtf" Value="$(var.SourceDir)\LICENSE.rtf" />

        <!-- ── Remove Previous Version ───────────────────────────────── -->
        <Property Id="PREVIOUSVERSIONSINSTALLED" Secure="yes" />
        <Upgrade Id="7A4C9F82-1E3B-4F6D-8C0A-5B2D7E9F1A3C">
            <UpgradeVersion Minimum="1.0.0"
                            Maximum="99.0.0"
                            Property="PREVIOUSVERSIONSINSTALLED"
                            IncludeMinimum="yes"
                            IncludeMaximum="no"
                            OnlyDetect="no" />
        </Upgrade>

        <!-- Remove previous version's files -->
        <CustomAction Id="CleanupPreviousInstall"
                      Directory="INSTALLDIR"
                      Execute="deferred"
                      Impersonate="no"
                      Return="ignore"
                      ExeCommand="[SystemFolder]cmd.exe /c &quot;if exist [INSTALLDIR]Thalamus.exe del /f /q [INSTALLDIR]Thalamus.exe &amp; if exist [INSTALLDIR]thalamus-vm-bridge.exe del /f /q [INSTALLDIR]thalamus-vm-bridge.exe&quot;" />

        <InstallExecuteSequence>
            <Custom Action="CleanupPreviousInstall" Before="InstallFiles">
                <![CDATA[PREVIOUSVERSIONSINSTALLED]]>
            </Custom>
        </InstallExecuteSequence>
    </Product>
</Wix>
