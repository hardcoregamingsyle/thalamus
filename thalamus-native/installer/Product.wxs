<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
    <Package
        Name="Thalamus AI"
        Manufacturer="Thalamus AI"
        Version="1.0.0"
        UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
        Scope="perMachine">

        <MajorUpgrade DowngradeErrorMessage="A newer version of Thalamus AI is already installed." />

        <MediaTemplate EmbedCab="yes" />

        <!-- ── Properties ──────────────────────────────────────────── -->
        <Property Id="ARPPRODUCTICON" Value="AppIcon.exe" />
        <Property Id="ARPHELPLINK" Value="https://thalamus.ai/support" />
        <Property Id="ARPURLINFOABOUT" Value="https://thalamus.ai" />
        <Property Id="ARPNOREPAIR" Value="1" />
        <Property Id="ARPNOMODIFY" Value="1" />

        <!-- ── Install sequence ─────────────────────────────────────── -->
        <StandardDirectory Id="ProgramFiles64Folder">
            <Directory Id="APPLICATIONFOLDER" Name="Thalamus AI">
                <!-- Main executable -->
                <Component Id="MainExecutable" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
                    <File Id="ThalamusExe" Name="Thalamus.exe" Source="Thalamus.exe" KeyPath="yes">
                        <Shortcut Id="StartMenuShortcut" Directory="ProgramMenuFolder" Name="Thalamus AI" Advertise="yes" />
                        <Shortcut Id="DesktopShortcut" Directory="DesktopFolder" Name="Thalamus AI" Advertise="yes" />
                    </File>
                </Component>

                <!-- Data directory for VM disk images -->
                <Directory Id="DataDirectory" Name="data">
                    <Component Id="DataDirectoryComponent" Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
                        <CreateFolder />
                        <IniFile Id="DataPathIni" Directory="DataDirectory" Name="settings.ini" Key="DataPath" Value="[DataDirectory]" />
                    </Component>
                </Directory>

                <!-- Registry entries -->
                <Component Id="RegistryEntries" Guid="D4E5F6A7-B8C9-0123-DEF1-234567890123">
                    <RegistryKey Root="HKLM" Key="SOFTWARE\Thalamus AI">
                        <RegistryValue Name="InstallPath" Type="string" Value="[APPLICATIONFOLDER]" KeyPath="yes" />
                        <RegistryValue Name="Version" Type="string" Value="1.0.0" />
                        <RegistryValue Name="DataPath" Type="string" Value="[DataDirectory]" />
                    </RegistryKey>
                    <!-- URI scheme: thalamus:// -->
                    <RegistryKey Root="HKCR" Key="thalamus">
                        <RegistryValue Type="string" Value="URL:Thalamus AI Protocol" />
                        <RegistryValue Name="URL Protocol" Type="string" Value="" />
                        <RegistryKey Key="shell\open\command">
                            <RegistryValue Type="string" Value="&quot;[APPLICATIONFOLDER]Thalamus.exe&quot; &quot;%1&quot;" />
                        </RegistryKey>
                    </RegistryKey>
                </Component>
            </Directory>
        </StandardDirectory>

        <!-- ── Start Menu folder ────────────────────────────────────── -->
        <StandardDirectory Id="ProgramMenuFolder">
            <Directory Id="ApplicationProgramsFolder" Name="Thalamus AI">
                <Component Id="StartMenuEntries" Guid="E5F6A7B8-C9D0-1234-EF23-456789012345">
                    <Shortcut Id="AppShortcut" Directory="ApplicationProgramsFolder" Name="Thalamus AI" Target="[APPLICATIONFOLDER]Thalamus.exe" WorkingDirectory="APPLICATIONFOLDER" />
                    <Shortcut Id="UninstallShortcut" Directory="ApplicationProgramsFolder" Name="Uninstall Thalamus AI" Target="[System64Folder]msiexec.exe" Arguments="/x [ProductCode]" />
                    <RemoveFolder Id="ApplicationProgramsFolder" On="uninstall" />
                    <RegistryValue Root="HKCU" Key="SOFTWARE\Thalamus AI" Name="Shortcuts" Type="integer" Value="1" KeyPath="yes" />
                </Component>
            </Directory>
        </StandardDirectory>

        <!-- ── Features ──────────────────────────────────────────────── -->
        <Feature Id="MainFeature" Title="Thalamus AI" Level="1">
            <ComponentRef Id="MainExecutable" />
            <ComponentRef Id="DataDirectoryComponent" />
            <ComponentRef Id="RegistryEntries" />
            <ComponentRef Id="StartMenuEntries" />
        </Feature>

        <!-- ── UI ────────────────────────────────────────────────────── -->
        <UI Id="WixUI">
            <UIRef Id="WixUI_Minimal" />
            <Property Id="WIXUI_INSTALLDIR" Value="APPLICATIONFOLDER" />
        </UI>

        <!-- ── Icon ──────────────────────────────────────────────────── -->
        <Icon Id="AppIcon.exe" SourceFile="..\ThalamusApp\resources\icons\app.ico" />
    </Package>
</Wix>
