<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/bal">

    <Bundle
        Name="Thalamus AI Setup"
        Version="1.0.0"
        Manufacturer="Thalamus AI"
        UpgradeCode="F6A7B8C9-D0E1-2345-EFAB-567890123456"
        Copyright="Thalamus AI"
        IconSourceFile="..\ThalamusApp\resources\icons\app.ico">

        <bal:Condition Message="Thalamus AI Setup requires Windows 10 or later.">
            VersionNT >= 100
        </bal:Condition>

        <!-- ── VC++ Redistributable prerequisite ──────────────────── -->
        <Chain>
            <ExePackage
                Id="VCRedist"
                Name="vc_redist.x64.exe"
                DownloadUrl="https://aka.ms/vs/17/release/vc_redist.x64.exe"
                InstallCommand="/install /quiet /norestart"
                RepairCommand="/repair /quiet /norestart"
                DetectCondition="MsiProductSearch({F2E1B3C4-D5E6-7890-ABCD-EF1234567890})"
                PerMachine="yes"
                Permanent="yes" />

            <!-- ── Thalamus MSI ───────────────────────────────────── -->
            <MsiPackage
                Id="ThalamusApp"
                SourceFile="..\dist\Thalamus-Setup-v1.0.0.msi"
                DisplayInternalUI="no"
                Vital="yes" />
        </Chain>
    </Bundle>
</Wix>
