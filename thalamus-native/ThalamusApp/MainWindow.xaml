<Window x:Class="ThalamusApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:modes="clr-namespace:ThalamusApp.Modes"
        Title="Thalamus AI"
        Width="1500" Height="940"
        MinWidth="960" MinHeight="600"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#050a14"
        WindowStartupLocation="CenterScreen"
        StateChanged="Window_StateChanged"
        Closing="OnClosing">

    <Window.Resources>
        <!-- ═══ PREMIUM COLOR PALETTE — Website dark theme exact match ═══ -->
        <Color x:Key="BgDeep">#050a14</Color>
        <Color x:Key="BgDarker">#020b1d</Color>
        <Color x:Key="BgCard">#0a1628</Color>
        <Color x:Key="BgHover">#162a4a</Color>
        <Color x:Key="BgActive">#1a3055</Color>
        <Color x:Key="BorderColor">#1e3a5f</Color>
        <Color x:Key="BorderDim">#142a48</Color>
        <Color x:Key="TextPrimary">#e2e8f0</Color>
        <Color x:Key="TextSecondary">#8899aa</Color>
        <Color x:Key="TextMuted">#3a506a</Color>
        <Color x:Key="BlueAccent">#3b82f6</Color>
        <Color x:Key="BlueGlow">#2563eb</Color>
        <Color x:Key="GreenAccent">#10b981</Color>
        <Color x:Key="AmberAccent">#f59e0b</Color>
        <Color x:Key="PurpleAccent">#8b5cf6</Color>
        <Color x:Key="RedAccent">#ef4444</Color>

        <!-- Brushes -->
        <SolidColorBrush x:Key="BgDeepBrush"      Color="{StaticResource BgDeep}"/>
        <SolidColorBrush x:Key="BgDarkerBrush"    Color="{StaticResource BgDarker}"/>
        <SolidColorBrush x:Key="BgCardBrush"      Color="{StaticResource BgCard}"/>
        <SolidColorBrush x:Key="BgHoverBrush"     Color="{StaticResource BgHover}"/>
        <SolidColorBrush x:Key="BgActiveBrush"    Color="{StaticResource BgActive}"/>
        <SolidColorBrush x:Key="BorderBrush"      Color="{StaticResource BorderColor}"/>
        <SolidColorBrush x:Key="BorderDimBrush"   Color="{StaticResource BorderDim}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="TextMutedBrush"   Color="{StaticResource TextMuted}"/>
        <SolidColorBrush x:Key="BlueBrush"        Color="{StaticResource BlueAccent}"/>
        <SolidColorBrush x:Key="GreenBrush"       Color="{StaticResource GreenAccent}"/>
        <SolidColorBrush x:Key="AmberBrush"       Color="{StaticResource AmberAccent}"/>
        <SolidColorBrush x:Key="PurpleBrush"      Color="{StaticResource PurpleAccent}"/>
        <SolidColorBrush x:Key="RedBrush"         Color="{StaticResource RedAccent}"/>

        <!-- Gradients -->
        <LinearGradientBrush x:Key="BlueGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#3b82f6" Offset="0"/>
            <GradientStop Color="#6366f1" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#030815" Offset="0"/>
            <GradientStop Color="#060d20" Offset="0.5"/>
            <GradientStop Color="#040a18" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ContentBgGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#070e22" Offset="0"/>
            <GradientStop Color="#050a14" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="StatusBarGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#020b1d" Offset="0"/>
            <GradientStop Color="#030612" Offset="1"/>
        </LinearGradientBrush>

        <!-- Traffic light button style -->
        <Style x:Key="TrafficLightBtn" TargetType="Button">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="Dot" Fill="{TemplateBinding Background}"
                                     Width="12" Height="12"
                                     Stroke="{TemplateBinding BorderBrush}" StrokeThickness="0.5"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Dot" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Dot" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar nav button -->
        <Style x:Key="SidebarBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,0,16,0"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Margin" Value="6,1,6,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- Border can only have one child — use a Grid to stack the accent bar and content -->
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Border x:Name="ActiveBar"
                                        Width="3" Height="0"
                                        CornerRadius="2"
                                        Background="{StaticResource BlueGradient}"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Margin="-16,0,0,0"
                                        Opacity="0"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active sidebar nav button -->
        <Style x:Key="SidebarBtnActive" TargetType="Button" BasedOn="{StaticResource SidebarBtn}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{StaticResource BgActiveBrush}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Border Width="3" Height="20"
                                        CornerRadius="2"
                                        Background="{StaticResource BlueGradient}"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Margin="-16,0,0,0"
                                        Opacity="1"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BgHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary action button -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BlueGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ghost button (subtle outline) -->
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDimBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ═══ ROOT LAYOUT ═══ -->
    <Grid>
        <!-- Background -->
        <Rectangle Fill="#050a14"/>

        <!-- Ambient glow - top-left blue -->
        <Rectangle HorizontalAlignment="Left" VerticalAlignment="Top"
                   Width="600" Height="500" Opacity="0.07">
            <Rectangle.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#3b82f6" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Ambient glow - bottom-right purple -->
        <Rectangle HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Width="400" Height="400" Opacity="0.04">
            <Rectangle.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#8b5cf6" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Subtle grid pattern overlay -->
        <Rectangle Opacity="0.04">
            <Rectangle.Fill>
                <DrawingBrush Viewport="0,0,40,40" ViewportUnits="Absolute" TileMode="Tile">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing>
                            <GeometryDrawing.Geometry>
                                <RectangleGeometry Rect="0,0,40,40"/>
                            </GeometryDrawing.Geometry>
                            <GeometryDrawing.Pen>
                                <Pen Thickness="0.5" Brush="#3b82f6"/>
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Main grid -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>

            <!-- ═══ TITLE BAR ═══ -->
            <Border Grid.Row="0" Background="{StaticResource BgDarkerBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Traffic lights + branding -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="16,0,0,0">
                        <!-- Red -->
                        <Button Style="{StaticResource TrafficLightBtn}"
                                Background="#ff5f57" BorderBrush="#e04844"
                                ToolTip="Close" Click="ClsBtn_Click"/>
                        <Button Style="{StaticResource TrafficLightBtn}"
                                Background="#febc2e" BorderBrush="#dda020"
                                ToolTip="Minimize" Click="MinBtn_Click"
                                Margin="8,0,0,0"/>
                        <Button x:Name="MaxBtn"
                                Style="{StaticResource TrafficLightBtn}"
                                Background="#28c840" BorderBrush="#20a830"
                                ToolTip="Maximize" Click="MaxBtn_Click"
                                Margin="8,0,0,0"/>

                        <Separator Margin="14,0,14,0" Width="1"
                                   Background="{StaticResource BorderBrush}" Height="18"/>

                        <!-- Logo -->
                        <Border Width="18" Height="18" CornerRadius="5"
                                Background="{StaticResource BlueGradient}">
                            <TextBlock Text="T" FontSize="9" FontWeight="Black"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Thalamus" FontSize="11.5" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>

                        <Border CornerRadius="8" Background="#0d1f3c"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" Padding="6,1,6,2" Margin="8,0,0,0">
                            <TextBlock Text="L4.5" FontSize="8" FontWeight="Bold"
                                       Foreground="{StaticResource BlueBrush}"/>
                        </Border>
                    </StackPanel>

                    <!-- Center: Auth status -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border x:Name="AuthDot" Width="6" Height="6" CornerRadius="3"
                                Background="{StaticResource AmberBrush}"
                                VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="UserLabel" Text=""
                                   FontSize="10.5" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <!-- Right: spacer (traffic lights already on left) -->
                </Grid>
            </Border>

            <!-- ═══ MAIN CONTENT ═══ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── SIDEBAR ── -->
                <Border Grid.Column="0" Background="{StaticResource SidebarGradient}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    <DockPanel>
                        <!-- Top gradient accent line -->
                        <Border DockPanel.Dock="Top" Height="2"
                                Background="{StaticResource BlueGradient}" Opacity="0.4"/>

                        <!-- Modes header -->
                        <Border DockPanel.Dock="Top" Padding="24,22,24,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="MODES"
                                           FontSize="8.5" FontWeight="Bold"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                                <Ellipse Width="3" Height="3"
                                         Fill="{StaticResource TextMutedBrush}"
                                         Opacity="0.4" Margin="8,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Mode navigation -->
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                            <!-- Build (Code) -->
                            <Button x:Name="BtnCode" Tag="Code"
                                    Click="Nav_Click" Style="{StaticResource SidebarBtnActive}">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="22" Height="22" CornerRadius="6"
                                            Background="#061a10" Margin="0,0,12,0"
                                            BorderBrush="#0a3018" BorderThickness="1">
                                        <Path Data="M13 10V3L4 14h7v7l9-11h-7z"
                                              Fill="{StaticResource GreenBrush}"
                                              Width="10" Height="10" Stretch="Uniform"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Build" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <!-- Chat -->
                            <Button x:Name="BtnChat" Tag="Chat"
                                    Click="Nav_Click" Style="{StaticResource SidebarBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="22" Height="22" CornerRadius="6"
                                            Background="#0d1f3c" Margin="0,0,12,0"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1">
                                        <Path Data="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                                              Stroke="{StaticResource TextSecondaryBrush}"
                                              StrokeThickness="1.4" Fill="Transparent"
                                              Width="11" Height="11" Stretch="Uniform"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Chat" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <!-- Research -->
                            <Button x:Name="BtnResearch" Tag="Research"
                                    Click="Nav_Click" Style="{StaticResource SidebarBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="22" Height="22" CornerRadius="6"
                                            Background="#0d1f3c" Margin="0,0,12,0"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1">
                                        <Path Data="M21 21 L15 15 M17 11 A6 6 0 1 1 5 11 A6 6 0 0 1 17 11 Z"
                                              Stroke="{StaticResource TextSecondaryBrush}"
                                              StrokeThickness="1.4" Fill="Transparent"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              Width="11" Height="11" Stretch="Uniform"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Research" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <!-- Study -->
                            <Button x:Name="BtnStudy" Tag="Study"
                                    Click="Nav_Click" Style="{StaticResource SidebarBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="22" Height="22" CornerRadius="6"
                                            Background="#0d1f3c" Margin="0,0,12,0"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1">
                                        <Path Data="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"
                                              Stroke="{StaticResource TextSecondaryBrush}"
                                              StrokeThickness="1.3" Fill="Transparent"
                                              StrokeLineJoin="Round"
                                              Width="11" Height="11" Stretch="Uniform"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Study" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Divider -->
                        <Border DockPanel.Dock="Top" Height="1"
                                Background="{StaticResource BorderBrush}" Opacity="0.4"
                                Margin="20,0,20,0"/>

                        <!-- Section: Account / Sign In -->
                        <Border DockPanel.Dock="Top" Padding="24,16,24,8">
                            <TextBlock x:Name="SectionLabel" Text="ACCOUNT"
                                       FontSize="8.5" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                        </Border>

                        <!-- Sign in button (visible when guest) -->
                        <Button x:Name="BtnSignIn" Tag="SignIn"
                                Click="Nav_Click" Style="{StaticResource SidebarBtn}"
                                Visibility="Visible">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="22" Height="22" CornerRadius="6"
                                        Background="#0d1f3c" Margin="0,0,12,0"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1">
                                    <!-- Lock icon path -->
                                    <Path Data="M19 11H5a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7a2 2 0 0 0-2-2z M7 11V7a5 5 0 0 1 10 0v4"
                                          Stroke="{StaticResource BlueBrush}"
                                          StrokeThickness="1.5" Fill="Transparent"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                          Width="11" Height="11" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Sign In" VerticalAlignment="Center"
                                           Foreground="{StaticResource BlueBrush}"/>
                            </StackPanel>
                        </Button>

                        <!-- Sign out button (visible when authenticated) -->
                        <Button x:Name="BtnSignOut" Tag="Logout"
                                Click="Nav_Click" Style="{StaticResource SidebarBtn}"
                                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="22" Height="22" CornerRadius="6"
                                        Background="#0d1f3c" Margin="0,0,12,0"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1">
                                    <!-- Log-out arrow icon -->
                                    <Path Data="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4 M16 17l5-5-5-5 M21 12H9"
                                          Stroke="{StaticResource TextSecondaryBrush}"
                                          StrokeThickness="1.5" Fill="Transparent"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Width="11" Height="11" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Sign Out" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Spacer -->
                        <Grid/>

                        <!-- Bottom section: version + update -->
                        <Border DockPanel.Dock="Bottom" Padding="20,14"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,1,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="5" Height="5" Fill="{StaticResource GreenBrush}"
                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="VersionLabel" Text="v1.0.0"
                                               FontSize="9.5" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Text="  ·  " FontSize="9.5"
                                               Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock x:Name="UpdateLabel" Text="Up to date"
                                               FontSize="9.5" Foreground="{StaticResource GreenBrush}"/>
                                </StackPanel>
                                <TextBlock x:Name="UpdateSubLabel" Text=""
                                           FontSize="8.5" Foreground="{StaticResource TextMutedBrush}"
                                           Margin="13,3,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </DockPanel>
                </Border>

                <!-- ── CONTENT AREA ── -->
                <Grid Grid.Column="1" Background="{StaticResource ContentBgGradient}">
                    <!-- Subtle inner glow -->
                    <Rectangle HorizontalAlignment="Left" VerticalAlignment="Top"
                               Width="300" Height="300" Opacity="0.05">
                        <Rectangle.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#3b82f6" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <modes:CodeView     x:Name="CodePanel"     Visibility="Visible"/>
                    <modes:ChatView     x:Name="ChatPanel"     Visibility="Collapsed"/>
                    <modes:ResearchView x:Name="ResearchPanel" Visibility="Collapsed"/>
                    <modes:StudyView    x:Name="StudyPanel"    Visibility="Collapsed"/>
                </Grid>
            </Grid>

            <!-- ═══ STATUS BAR ═══ -->
            <Border Grid.Row="2" Background="{StaticResource StatusBarGradient}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0" Padding="14,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="4" Height="4" Fill="{StaticResource GreenBrush}"
                                 VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock x:Name="StatusText" Text="Ready"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="9.5"/>
                    </StackPanel>
                    <Border Grid.Column="1" CornerRadius="4"
                            Background="#0d1f3c"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="8,1,8,2" VerticalAlignment="Center">
                        <TextBlock x:Name="ModeLabel" Text="Code Mode"
                                   Foreground="{StaticResource BlueBrush}"
                                   FontSize="8.5" FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
