<Window x:Class="ThalamusApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:modes="clr-namespace:ThalamusApp.Modes"
        xmlns:local="clr-namespace:ThalamusApp"
        Title="Thalamus AI"
        Icon="Assets/logo.png"
        Width="1500" Height="940"
        MinWidth="960" MinHeight="600"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="{DynamicResource BgDarkerBrush}"
        FontFamily="{StaticResource AppFontFamily}"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen"
        StateChanged="Window_StateChanged"
        Closing="OnClosing">

    <Window.Resources>
        <!-- Shared colors/brushes/gradients are in App.xaml Application.Resources -->
        <!-- Only window-specific styles remain here -->

        <!-- Traffic light button style -->
        <Style x:Key="TrafficLightBtn" TargetType="Button">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="Dot" Fill="{TemplateBinding Background}"
                                     Width="12" Height="12"
                                     Stroke="{TemplateBinding BorderBrush}" StrokeThickness="0.5"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Dot" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Dot" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar nav button -->
        <Style x:Key="SidebarBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,0,16,0"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Margin" Value="6,1,6,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- Border can only have one child — use a Grid to stack the accent bar and content -->
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Border x:Name="ActiveBar"
                                        Width="3" Height="0"
                                        CornerRadius="2"
                                        Background="{DynamicResource BlueGradient}"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Margin="-16,0,0,0"
                                        Opacity="0"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active sidebar nav button -->
        <Style x:Key="SidebarBtnActive" TargetType="Button" BasedOn="{StaticResource SidebarBtn}">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{DynamicResource BgActiveBrush}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Border Width="3" Height="20"
                                        CornerRadius="2"
                                        Background="{DynamicResource BlueGradient}"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Margin="-16,0,0,0"
                                        Opacity="1"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BgHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ═══ ROOT LAYOUT ═══ -->
    <Grid>
        <!-- Background -->
        <Rectangle Fill="{DynamicResource BgDarkerBrush}"/>

        <!-- Ambient glow - top-left blue -->
        <Rectangle HorizontalAlignment="Left" VerticalAlignment="Top"
                   Width="600" Height="500" Opacity="0.07">
            <Rectangle.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#0088f1" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Ambient glow - bottom-right purple -->
        <Rectangle HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Width="400" Height="400" Opacity="0.04">
            <Rectangle.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#8b5cf6" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Subtle grid pattern overlay -->
        <Rectangle Opacity="0.04">
            <Rectangle.Fill>
                <DrawingBrush Viewport="0,0,40,40" ViewportUnits="Absolute" TileMode="Tile">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing>
                            <GeometryDrawing.Geometry>
                                <RectangleGeometry Rect="0,0,40,40"/>
                            </GeometryDrawing.Geometry>
                            <GeometryDrawing.Pen>
                                <Pen Thickness="0.5" Brush="#0088f1"/>
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Main grid -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>

            <!-- ═══ TITLE BAR ═══ -->
            <Border Grid.Row="0" Background="{DynamicResource BgDarkerBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Traffic lights + branding -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="16,0,0,0">
                        <!-- Red -->
                        <Button Style="{StaticResource TrafficLightBtn}"
                                Background="#ff5f57" BorderBrush="#e04844"
                                ToolTip="Close" Click="ClsBtn_Click"/>
                        <Button Style="{StaticResource TrafficLightBtn}"
                                Background="#febc2e" BorderBrush="#dda020"
                                ToolTip="Minimize" Click="MinBtn_Click"
                                Margin="8,0,0,0"/>
                        <Button x:Name="MaxBtn"
                                Style="{StaticResource TrafficLightBtn}"
                                Background="#28c840" BorderBrush="#20a830"
                                ToolTip="Maximize" Click="MaxBtn_Click"
                                Margin="8,0,0,0"/>

                        <Separator Margin="14,0,14,0" Width="1"
                                   Background="{DynamicResource BorderBrush}" Height="18"/>

                        <!-- Logo -->
                        <Border Width="18" Height="18" CornerRadius="5"
                                Background="{DynamicResource BlueGradient}">
                            <TextBlock Text="T" FontSize="9" FontWeight="Black"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Thalamus" FontSize="11.5" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>

                        <Border CornerRadius="8" Background="{DynamicResource TintBlueBgBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" Padding="6,1,6,2" Margin="8,0,0,0">
                            <TextBlock Text="Desktop" FontSize="8" FontWeight="Bold"
                                       Foreground="{DynamicResource BlueBrush}"/>
                        </Border>
                    </StackPanel>

                    <!-- Center: Auth status -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border x:Name="AuthDot" Width="6" Height="6" CornerRadius="3"
                                Background="{DynamicResource AmberBrush}"
                                VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="UserLabel" Text=""
                                   FontSize="10.5" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <!-- Right: light/dark toggle (mirrors the website's theme switch) -->
                    <Button Grid.Column="2" x:Name="BtnTheme" Click="ThemeToggle_Click"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Width="34" Margin="0,0,10,0"
                            ToolTip="Toggle light / dark theme">
                        <TextBlock x:Name="ThemeIcon" Text="☀" FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Button>
                </Grid>
            </Border>

            <!-- ═══ MAIN CONTENT ═══ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── SIDEBAR ── -->
                <Border Grid.Column="0" Background="{DynamicResource SidebarGradient}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    <DockPanel>
                        <!-- Top gradient accent line -->
                        <Border DockPanel.Dock="Top" Height="2"
                                Background="{DynamicResource BlueGradient}" Opacity="0.4"/>

                        <!-- Modes header -->
                        <Border DockPanel.Dock="Top" Padding="24,22,24,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="MODES"
                                           FontSize="8.5" FontWeight="Bold"
                                           Foreground="{DynamicResource TextMutedBrush}"/>
                                <Ellipse Width="3" Height="3"
                                         Fill="{DynamicResource TextMutedBrush}"
                                         Opacity="0.4" Margin="8,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Mode navigation -->
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                            <!-- Build (Code) -->
                            <Button x:Name="BtnCode" Tag="Code"
                                    Click="Nav_Click" Style="{StaticResource SidebarBtnActive}">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="22" Height="22" CornerRadius="6"
                                            Background="{DynamicResource TintGreenBgBrush}" Margin="0,0,12,0"
                                            BorderBrush="{DynamicResource TintGreenBorderBrush}" BorderThickness="1">
                                        <Path Data="M13 10V3L4 14h7v7l9-11h-7z"
                                              Fill="{DynamicResource GreenBrush}"
                                              Width="10" Height="10" Stretch="Uniform"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Build" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <!-- Chat -->
                            <Button x:Name="BtnChat" Tag="Chat"
                                    Click="Nav_Click" Style="{StaticResource SidebarBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="22" Height="22" CornerRadius="6"
                                            Background="{DynamicResource TintBlueBgBrush}" Margin="0,0,12,0"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1">
                                        <Path Data="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                                              Stroke="{DynamicResource TextSecondaryBrush}"
                                              StrokeThickness="1.4" Fill="Transparent"
                                              Width="11" Height="11" Stretch="Uniform"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Chat" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <!-- Research -->
                            <Button x:Name="BtnResearch" Tag="Research"
                                    Click="Nav_Click" Style="{StaticResource SidebarBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="22" Height="22" CornerRadius="6"
                                            Background="{DynamicResource TintBlueBgBrush}" Margin="0,0,12,0"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1">
                                        <Path Data="M21 21 L15 15 M17 11 A6 6 0 1 1 5 11 A6 6 0 0 1 17 11 Z"
                                              Stroke="{DynamicResource TextSecondaryBrush}"
                                              StrokeThickness="1.4" Fill="Transparent"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              Width="11" Height="11" Stretch="Uniform"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Research" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <!-- Study -->
                            <Button x:Name="BtnStudy" Tag="Study"
                                    Click="Nav_Click" Style="{StaticResource SidebarBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="22" Height="22" CornerRadius="6"
                                            Background="{DynamicResource TintBlueBgBrush}" Margin="0,0,12,0"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1">
                                        <Path Data="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"
                                              Stroke="{DynamicResource TextSecondaryBrush}"
                                              StrokeThickness="1.3" Fill="Transparent"
                                              StrokeLineJoin="Round"
                                              Width="11" Height="11" Stretch="Uniform"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Study" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <!-- Sandbox (QEMU VMs) -->
                            <Button x:Name="BtnSandbox" Tag="Sandbox"
                                    Click="Nav_Click" Style="{StaticResource SidebarBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="22" Height="22" CornerRadius="6"
                                            Background="{DynamicResource TintBlueBgBrush}" Margin="0,0,12,0"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1">
                                        <Path Data="M20 3H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2z M8 21h8 M12 17v4"
                                              Stroke="{DynamicResource TextSecondaryBrush}"
                                              StrokeThickness="1.4" Fill="Transparent"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Width="11" Height="11" Stretch="Uniform"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Sandbox" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Divider -->
                        <Border DockPanel.Dock="Top" Height="1"
                                Background="{DynamicResource BorderBrush}" Opacity="0.4"
                                Margin="20,0,20,0"/>

                        <!-- Section: Account / Sign In -->
                        <Border DockPanel.Dock="Top" Padding="24,16,24,8">
                            <TextBlock x:Name="SectionLabel" Text="ACCOUNT"
                                       FontSize="8.5" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                        </Border>

                        <!-- Account rows stack vertically; the StackPanel keeps them
                             docked as one Top block regardless of DockPanel defaults. -->
                        <StackPanel DockPanel.Dock="Top">

                        <!-- AgentBucks balance (visible when authenticated). Mirrors the
                             website's readout: daily allowance + purchased, formatted N0. -->
                        <Border x:Name="CreditsRow" Height="44" Margin="6,1,6,1"
                                Padding="16,0,16,0" CornerRadius="8"
                                Visibility="Collapsed"
                                ToolTip="AgentBucks — daily allowance + purchased credits">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="22" Height="22" CornerRadius="6"
                                        Background="{DynamicResource TintAmberBgBrush}" Margin="0,0,12,0"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1">
                                    <Path Data="M13 10V3L4 14h7v7l9-11h-7z"
                                          Fill="{DynamicResource AmberBrush}"
                                          Width="11" Height="11" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="CreditsLabel" Text="—"
                                           VerticalAlignment="Center" FontSize="11.5"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Buy Credits button (visible when authenticated) -->
                        <Button x:Name="BtnBuyCredits"
                                Click="BuyCredits_Click" Style="{StaticResource SidebarBtn}"
                                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="22" Height="22" CornerRadius="6"
                                        Background="{DynamicResource TintAmberBgBrush}" Margin="0,0,12,0"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1">
                                    <!-- Lightning bolt — echoes the AgentBucks/credits accent -->
                                    <Path Data="M13 10V3L4 14h7v7l9-11h-7z"
                                          Fill="{DynamicResource AmberBrush}"
                                          Width="11" Height="11" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Buy Credits" VerticalAlignment="Center"
                                           Foreground="{DynamicResource AmberBrush}"/>
                            </StackPanel>
                        </Button>

                        <!-- Sign out button (visible when authenticated) -->
                        <Button x:Name="BtnSignOut" Tag="Logout"
                                Click="Nav_Click" Style="{StaticResource SidebarBtn}"
                                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="22" Height="22" CornerRadius="6"
                                        Background="{DynamicResource TintBlueBgBrush}" Margin="0,0,12,0"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1">
                                    <!-- Log-out arrow icon -->
                                    <Path Data="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4 M16 17l5-5-5-5 M21 12H9"
                                          Stroke="{DynamicResource TextSecondaryBrush}"
                                          StrokeThickness="1.5" Fill="Transparent"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Width="11" Height="11" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Sign Out" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        </StackPanel>

                        <!-- Bottom section: version + update. Declared before the
                             recents list so Dock=Bottom wins the layout pass and the
                             list (last child) fills whatever height remains. -->
                        <Border DockPanel.Dock="Bottom" Padding="20,14"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="5" Height="5" Fill="{DynamicResource GreenBrush}"
                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="VersionLabel" Text="v1.0.0"
                                               FontSize="9.5" FontFamily="{StaticResource MonoFontFamily}"
                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBlock Text="  ·  " FontSize="9.5"
                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBlock x:Name="UpdateLabel" Text="Up to date"
                                               FontSize="9.5" Foreground="{DynamicResource GreenBrush}"/>
                                </StackPanel>
                                <TextBlock x:Name="UpdateSubLabel" Text=""
                                           FontSize="8.5" Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="13,3,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- RECENT — past conversations for the active chat-ish mode
                             (Chat/Research/Study). Hidden for Build and Sandbox, which
                             have their own project/VM lists. Last child → fills. -->
                        <DockPanel x:Name="RecentSection" Visibility="Collapsed">
                            <Border DockPanel.Dock="Top" Padding="24,14,16,6">
                                <Grid>
                                    <TextBlock Text="RECENT"
                                               FontSize="8.5" FontWeight="Bold"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                    <Button x:Name="BtnNewChat" Click="NewChat_Click"
                                            HorizontalAlignment="Right"
                                            Background="Transparent" BorderThickness="0"
                                            Cursor="Hand" Padding="6,2"
                                            ToolTip="Start a new conversation">
                                        <TextBlock Text="+ New" FontSize="9.5" FontWeight="Bold"
                                                   Foreground="{DynamicResource BlueBrush}"/>
                                    </Button>
                                </Grid>
                            </Border>
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ScrollViewer.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBar}"/>
                                </ScrollViewer.Resources>
                                <StackPanel x:Name="RecentListPanel" Margin="0,0,0,8"/>
                            </ScrollViewer>
                        </DockPanel>
                    </DockPanel>
                </Border>

                <!-- ── CONTENT AREA ── -->
                <Grid Grid.Column="1" Background="{DynamicResource ContentBgGradient}">
                    <!-- Subtle inner glow -->
                    <Rectangle HorizontalAlignment="Left" VerticalAlignment="Top"
                               Width="300" Height="300" Opacity="0.05">
                        <Rectangle.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#0088f1" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <modes:CodeView     x:Name="CodePanel"     Visibility="Visible"/>
                    <modes:ChatView     x:Name="ChatPanel"     Visibility="Collapsed"/>
                    <modes:ResearchView x:Name="ResearchPanel" Visibility="Collapsed"/>
                    <modes:StudyView    x:Name="StudyPanel"    Visibility="Collapsed"/>
                    <local:SandboxView  x:Name="SandboxPanel"  Visibility="Collapsed"/>
                </Grid>
            </Grid>

            <!-- ═══ STATUS BAR ═══ -->
            <Border Grid.Row="2" Background="{DynamicResource StatusBarGradient}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0" Padding="14,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="4" Height="4" Fill="{DynamicResource GreenBrush}"
                                 VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock x:Name="StatusText" Text="Ready"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontFamily="{StaticResource MonoFontFamily}"
                                   FontSize="9.5"/>
                    </StackPanel>
                    <Border Grid.Column="1" CornerRadius="4"
                            Background="{DynamicResource TintBlueBgBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Padding="8,1,8,2" VerticalAlignment="Center">
                        <TextBlock x:Name="ModeLabel" Text="Code Mode"
                                   Foreground="{DynamicResource BlueBrush}"
                                   FontFamily="{StaticResource MonoFontFamily}"
                                   FontSize="8.5" FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
