<UserControl x:Class="ThalamusApp.SandboxView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:ThalamusApp"
      Background="#050a14"
      Foreground="#e2e8f0">

    <UserControl.Resources>
        <SolidColorBrush x:Key="Primary"    Color="#3b82f6"/>
        <SolidColorBrush x:Key="BgDarker"   Color="#020b1d"/>
        <SolidColorBrush x:Key="BgPanel"    Color="#0a1628"/>
        <SolidColorBrush x:Key="TextSec"    Color="#64748b"/>
        <SolidColorBrush x:Key="Border"     Color="#1e3a5f"/>
        <SolidColorBrush x:Key="Hover"      Color="#1a2d4a"/>
        <SolidColorBrush x:Key="Green"      Color="#10b981"/>
        <SolidColorBrush x:Key="Amber"      Color="#f59e0b"/>
        <SolidColorBrush x:Key="Red"        Color="#ef4444"/>

        <!-- Standard button -->
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource Hover}"/>
            <Setter Property="Foreground"   Value="#e2e8f0"/>
            <Setter Property="BorderBrush"  Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="12,8"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Primary}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- OS list item -->
        <Style x:Key="OsItem" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
        </Style>

        <!-- OS selected state — applied in code-behind -->
        <Style x:Key="OsItemActive" TargetType="Button" BasedOn="{StaticResource OsItem}">
            <Setter Property="Background"  Value="{StaticResource Primary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Primary}"/>
            <Setter Property="Foreground"  Value="White"/>
        </Style>

        <!-- Primary action -->
        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#2563eb" Offset="0"/>
                        <GradientStop Color="#4f46e5" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
        </Style>

        <!-- Slider -->
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="{StaticResource Primary}"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LEFT PANEL — OS picker + VM config ═══ -->
        <Border Grid.Column="0" Background="{StaticResource BgDarker}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
            <DockPanel Margin="0">

                <!-- Header -->
                <Border DockPanel.Dock="Top" Padding="16,14,16,10"
                        BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                    <TextBlock Text="Select Operating System" FontSize="13" FontWeight="SemiBold" Foreground="#e2e8f0"/>
                </Border>

                <!-- Action buttons at bottom -->
                <StackPanel DockPanel.Dock="Bottom" Margin="12,0,12,14">
                    <Separator Background="{StaticResource Border}" Height="1" Margin="0,0,0,12"/>
                    <Button x:Name="BootButton"  Content="🚀  Boot VM"  Style="{StaticResource PrimaryBtn}"
                            Height="42" FontSize="13" Click="BootButton_Click"/>
                    <Button x:Name="StopButton"  Content="⏹  Stop VM"  Style="{StaticResource Btn}"
                            Height="38" FontSize="12" Margin="0,6,0,0" IsEnabled="False" Click="StopButton_Click"/>
                    <Button x:Name="VncButton"   Content="🖥  Launch VNC" Style="{StaticResource Btn}"
                            Height="38" FontSize="12" Margin="0,6,0,0" IsEnabled="False" Click="LaunchVNCButton_Click"/>
                </StackPanel>

                <!-- Scrollable middle -->
                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,10,12,0">

                        <!-- Category: Windows -->
                        <TextBlock Text="WINDOWS" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextSec}" Margin="4,6,0,4"/>
                        <StackPanel x:Name="OsWindows"/>

                        <!-- Category: macOS -->
                        <TextBlock Text="macOS" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextSec}" Margin="4,10,0,4"/>
                        <StackPanel x:Name="OsMacos"/>

                        <!-- Category: Android -->
                        <TextBlock Text="ANDROID" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextSec}" Margin="4,10,0,4"/>
                        <StackPanel x:Name="OsAndroid"/>

                        <!-- Category: Linux -->
                        <TextBlock Text="LINUX" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextSec}" Margin="4,10,0,4"/>
                        <StackPanel x:Name="OsLinux"/>

                        <!-- VM Config -->
                        <Separator Background="{StaticResource Border}" Margin="4,14,4,14" Height="1"/>
                        <TextBlock Text="VM CONFIGURATION" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextSec}" Margin="4,0,0,10"/>

                        <Grid Margin="4,0,4,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="RAM" FontSize="12" Foreground="{StaticResource TextSec}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="RamLabel" Grid.Column="1" Text="4096 MB" FontSize="12"
                                       Foreground="#e2e8f0" FontWeight="SemiBold"/>
                        </Grid>
                        <Slider x:Name="RamSlider" Minimum="512" Maximum="16384" Value="4096"
                                TickFrequency="512" IsSnapToTickEnabled="True" Margin="4,4,4,12"/>

                        <Grid Margin="4,0,4,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="CPU Cores" FontSize="12" Foreground="{StaticResource TextSec}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="CoresLabel" Grid.Column="1" Text="4 Cores" FontSize="12"
                                       Foreground="#e2e8f0" FontWeight="SemiBold"/>
                        </Grid>
                        <Slider x:Name="CoresSlider" Minimum="1" Maximum="16" Value="4"
                                TickFrequency="1" IsSnapToTickEnabled="True" Margin="4,4,4,14"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ═══ RIGHT PANEL — display + console ═══ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="180"/>
            </Grid.RowDefinitions>

            <!-- Status bar -->
            <Border Grid.Row="0" Background="{StaticResource BgDarker}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="14,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="VmStatusDot" Width="8" Height="8" Fill="{StaticResource TextSec}" Margin="0,0,8,0"/>
                        <TextBlock x:Name="VmStatusText" Text="No VM running" FontSize="12"
                                   Foreground="{StaticResource TextSec}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="VncPortText" Text="" FontSize="12"
                                   Foreground="{StaticResource Primary}" Margin="14,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="↻ Refresh" Style="{StaticResource Btn}"
                            Click="RefreshButton_Click" Padding="10,4" FontSize="11"/>
                </Grid>
            </Border>

            <!-- VM display -->
            <Border Grid.Row="1" Background="#020b1d" Padding="16">
                <Grid>
                    <!-- Placeholder text -->
                    <StackPanel x:Name="DisplayPlaceholder" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="🖥" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock x:Name="DisplayText" Text="Select an OS and click Boot VM to start"
                                   FontSize="14" Foreground="{StaticResource TextSec}" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="IsoHint" Text="" FontSize="11" Foreground="{StaticResource Amber}"
                                   HorizontalAlignment="Center" Margin="0,8,0,0" TextWrapping="Wrap"
                                   MaxWidth="480" TextAlignment="Center"/>
                    </StackPanel>

                    <!-- Embedded VNC frame (WriteableBitmap) -->
                    <Image x:Name="VncFrame" Stretch="Uniform" Visibility="Collapsed"
                           HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                </Grid>
            </Border>

            <!-- Console panel -->
            <Border Grid.Row="2" Background="{StaticResource BgDarker}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="14,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Console" FontSize="11" FontWeight="SemiBold"
                               Foreground="#e2e8f0" Margin="0,0,0,6"/>

                    <ScrollViewer Grid.Row="1" x:Name="ConsoleScroll"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <TextBox x:Name="ConsoleOutput"
                                 Background="Transparent" Foreground="#10b981"
                                 BorderThickness="0" IsReadOnly="True"
                                 FontFamily="Consolas" FontSize="11"
                                 TextWrapping="Wrap" AcceptsReturn="True"/>
                    </ScrollViewer>

                    <Grid Grid.Row="2" Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="CommandInput"
                                 Background="#020b1d" Foreground="#e2e8f0"
                                 BorderBrush="{StaticResource Border}" BorderThickness="1"
                                 Padding="8,5" FontFamily="Consolas" FontSize="11"
                                 KeyDown="CommandInput_KeyDown"/>
                        <Button Grid.Column="1" Content="Send" Style="{StaticResource Btn}"
                                Margin="8,0,0,0" Padding="14,5" Click="SendCommand_Click"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
