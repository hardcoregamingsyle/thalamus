<UserControl x:Class="ThalamusApp.SandboxView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource ContentBgGradient}"
      Foreground="{StaticResource TextPrimaryBrush}">

    <UserControl.Resources>
        <!-- Palette, Card, PrimaryBtn, GhostBtn, ThemedSlider, ThemedInput,
             ThinScrollBar come from Styles/Theme.xaml -->

        <!-- Small inline action button used on catalog rows (Download/Delete/…) -->
        <Style x:Key="IsoActionBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDimBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="9,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LEFT PANEL — OS catalog + VM config ═══ -->
        <Border Grid.Column="0" Background="{StaticResource BgDarkerBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel Margin="0">

                <!-- Header -->
                <Border DockPanel.Dock="Top" Padding="16,14,16,12"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="Operating Systems" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Official images only — downloaded on demand"
                                   FontSize="9.5" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Action buttons at bottom -->
                <StackPanel DockPanel.Dock="Bottom" Margin="12,0,12,14">
                    <Separator Background="{StaticResource BorderBrush}" Height="1" Margin="0,0,0,12"/>
                    <Button x:Name="BootButton"  Content="Boot VM"  Style="{StaticResource PrimaryBtn}"
                            Height="42" FontSize="13" Click="BootButton_Click"/>
                    <Button x:Name="StopButton"  Content="Stop VM"  Style="{StaticResource GhostBtn}"
                            Height="36" FontSize="12" Margin="0,6,0,0" IsEnabled="False" Click="StopButton_Click"/>
                    <Button x:Name="VncButton"   Content="Launch external VNC" Style="{StaticResource GhostBtn}"
                            Height="36" FontSize="12" Margin="0,6,0,0" IsEnabled="False" Click="LaunchVNCButton_Click"/>
                </StackPanel>

                <!-- Scrollable middle -->
                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBar}"/>
                    </ScrollViewer.Resources>
                    <StackPanel Margin="12,10,12,0">

                        <TextBlock Text="WINDOWS" Style="{StaticResource SectionHeader}" Margin="4,6,0,4"/>
                        <StackPanel x:Name="OsWindows"/>

                        <TextBlock Text="ANDROID" Style="{StaticResource SectionHeader}" Margin="4,10,0,4"/>
                        <StackPanel x:Name="OsAndroid"/>

                        <TextBlock Text="LINUX" Style="{StaticResource SectionHeader}" Margin="4,10,0,4"/>
                        <StackPanel x:Name="OsLinux"/>

                        <TextBlock Text="YOUR ISO" Style="{StaticResource SectionHeader}" Margin="4,10,0,4"/>
                        <StackPanel x:Name="OsCustom"/>

                        <!-- VM Config -->
                        <Separator Background="{StaticResource BorderBrush}" Margin="4,14,4,14" Height="1"/>
                        <TextBlock Text="VM CONFIGURATION" Style="{StaticResource SectionHeader}" Margin="4,0,0,10"/>

                        <Grid Margin="4,0,4,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="RAM" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="RamLabel" Grid.Column="1" Text="4096 MB" FontSize="12"
                                       Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                        </Grid>
                        <Slider x:Name="RamSlider" Style="{StaticResource ThemedSlider}"
                                Minimum="512" Maximum="16384" Value="4096"
                                TickFrequency="512" IsSnapToTickEnabled="True" Margin="4,4,4,12"/>

                        <Grid Margin="4,0,4,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="CPU Cores" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="CoresLabel" Grid.Column="1" Text="4 Cores" FontSize="12"
                                       Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                        </Grid>
                        <Slider x:Name="CoresSlider" Style="{StaticResource ThemedSlider}"
                                Minimum="1" Maximum="16" Value="4"
                                TickFrequency="1" IsSnapToTickEnabled="True" Margin="4,4,4,14"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ═══ RIGHT PANEL — display + console ═══ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="180"/>
            </Grid.RowDefinitions>

            <!-- Status bar -->
            <Border Grid.Row="0" Background="{StaticResource BgDarkerBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="14,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="VmStatusDot" Width="8" Height="8"
                                 Fill="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                        <TextBlock x:Name="VmStatusText" Text="No VM running" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="VncPortText" Text="" FontSize="12"
                                   Foreground="{StaticResource BlueBrush}" Margin="14,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Refresh" Style="{StaticResource GhostBtn}"
                            Click="RefreshButton_Click" Height="26" Padding="10,0" FontSize="11"/>
                </Grid>
            </Border>

            <!-- VM display -->
            <Border Grid.Row="1" Background="{StaticResource BgDarkerBrush}" Padding="16">
                <Grid>
                    <!-- Placeholder text -->
                    <StackPanel x:Name="DisplayPlaceholder" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Width="56" Height="56" CornerRadius="14"
                                Background="{StaticResource BgCardBrush}"
                                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                                HorizontalAlignment="Center" Margin="0,0,0,14">
                            <Path Data="M20 3H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2z M8 21h8 M12 17v4"
                                  Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.5"
                                  Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" Width="26" Height="26" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="DisplayText" Text="Select an OS and click Boot VM to start"
                                   FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="IsoHint" Text="" FontSize="11" Foreground="{StaticResource AmberBrush}"
                                   HorizontalAlignment="Center" Margin="0,8,0,0" TextWrapping="Wrap"
                                   MaxWidth="480" TextAlignment="Center"/>
                    </StackPanel>

                    <!-- Embedded VNC frame (WriteableBitmap) -->
                    <Image x:Name="VncFrame" Stretch="Uniform" Visibility="Collapsed"
                           HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                </Grid>
            </Border>

            <!-- Console panel -->
            <Border Grid.Row="2" Background="{StaticResource BgDarkerBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="14,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Console" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>

                    <ScrollViewer Grid.Row="1" x:Name="ConsoleScroll"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBar}"/>
                        </ScrollViewer.Resources>
                        <TextBox x:Name="ConsoleOutput"
                                 Background="Transparent" Foreground="{StaticResource GreenBrush}"
                                 BorderThickness="0" IsReadOnly="True"
                                 FontFamily="Consolas" FontSize="11"
                                 TextWrapping="Wrap" AcceptsReturn="True"/>
                    </ScrollViewer>

                    <Grid Grid.Row="2" Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="CommandInput"
                                 Style="{StaticResource ThemedInput}"
                                 Padding="8,5" FontFamily="Consolas" FontSize="11"
                                 KeyDown="CommandInput_KeyDown"/>
                        <Button Grid.Column="1" Content="Send" Style="{StaticResource GhostBtn}"
                                Margin="8,0,0,0" Height="28" Padding="14,0" Click="SendCommand_Click"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
