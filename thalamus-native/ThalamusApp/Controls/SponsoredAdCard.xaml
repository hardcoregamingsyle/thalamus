<UserControl x:Class="ThalamusApp.Controls.SponsoredAdCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Left" Margin="0,0,0,16">

    <!-- Whole card is one click target (opens clickUrl ?? url in the browser).
         Background/BorderBrush live in the Style so the hover trigger can win —
         a local BorderBrush value would out-rank the trigger. -->
    <Border x:Name="CardBorder" Cursor="Hand" MaxWidth="520"
            CornerRadius="14" BorderThickness="1" Padding="16,12"
            MouseLeftButtonUp="Card_Click">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource BlueBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <StackPanel>
            <TextBlock Text="SPONSORED" FontSize="9" FontWeight="Bold"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Image x:Name="FaviconImage" Grid.Column="0"
                       Width="16" Height="16" VerticalAlignment="Top"
                       Margin="0,2,8,0" Visibility="Collapsed"
                       RenderOptions.BitmapScalingMode="HighQuality"/>

                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="TitleText" FontSize="12.5" FontWeight="Bold"
                               TextWrapping="Wrap" LineHeight="18"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="AdText" FontSize="11.5" TextWrapping="Wrap"
                               LineHeight="17" Margin="0,2,0,0" Visibility="Collapsed"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="CtaText" FontSize="11.5" FontWeight="Bold"
                               Margin="0,6,0,0" Visibility="Collapsed"
                               Foreground="{StaticResource BlueBrush}"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
