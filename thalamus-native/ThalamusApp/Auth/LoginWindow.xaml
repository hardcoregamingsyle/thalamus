<Window x:Class="ThalamusApp.Auth.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thalamus AI — Sign In"
        Width="480" Height="620"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Topmost="False">

    <Window.Resources>
        <!-- Colors matching website theme -->
        <Color x:Key="BgDark">#050a14</Color>
        <Color x:Key="BgCard">#0a1628</Color>
        <Color x:Key="BgDarker">#020b1d</Color>
        <Color x:Key="BorderColor">#1e3a5f</Color>
        <Color x:Key="TextPrimary">#e2e8f0</Color>
        <Color x:Key="TextSecondary">#64748b</Color>
        <Color x:Key="TextMuted">#334155</Color>
        <Color x:Key="BlueAccent">#3b82f6</Color>
        <Color x:Key="BlueGlow">#2563eb</Color>
        <Color x:Key="GreenAccent">#10b981</Color>
        <Color x:Key="AmberAccent">#f59e0b</Color>
        <Color x:Key="RedAccent">#ef4444</Color>

        <LinearGradientBrush x:Key="BlueGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#3b82f6" Offset="0"/>
            <GradientStop Color="#6366f1" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BgGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#050a14" Offset="0"/>
            <GradientStop Color="#080f24" Offset="0.5"/>
            <GradientStop Color="#050a14" Offset="1"/>
        </LinearGradientBrush>

        <DropShadowEffect x:Key="WindowShadow"
                          BlurRadius="20"
                          ShadowDepth="0"
                          Opacity="0.35"
                          Color="#3b82f6"/>

        <Style x:Key="GlowButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BlueGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2563eb"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1d4ed8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1a2d4a"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BlueAccent}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Window chrome with shadow -->
    <Border CornerRadius="16"
            Background="{StaticResource BgGradient}"
            BorderBrush="{StaticResource BorderColor}"
            BorderThickness="1"
            Effect="{StaticResource WindowShadow}"
            MouseLeftButtonDown="TitleBar_MouseDown">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ═══ Title Bar ═══ -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgDarker}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="16,16,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="16,0,0,0">
                        <Border Width="18" Height="18" CornerRadius="5"
                                Background="{StaticResource BlueGradient}">
                            <TextBlock Text="T" FontSize="9" FontWeight="Black"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Thalamus AI" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- Close button -->
                    <Button Grid.Column="1" Content="✕"
                            Background="Transparent"
                            Foreground="{StaticResource TextSecondary}"
                            BorderThickness="0"
                            Width="44" Height="44"
                            FontSize="14"
                            Cursor="Hand"
                            Click="CloseBtn_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                    CornerRadius="0,16,0,0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource RedAccent}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- ═══ Content ═══ -->
            <Grid Grid.Row="1" Margin="32,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,28,0,0">
                    <!-- Logo -->
                    <Border Width="48" Height="48" CornerRadius="14"
                            Background="{StaticResource BlueGradient}"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,16">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="24" ShadowDepth="0"
                                              Opacity="0.5" Color="#3b82f6"/>
                        </Border.Effect>
                        <TextBlock Text="T" FontSize="22" FontWeight="Black"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock x:Name="TitleText"
                               Text="Sign in to your account"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>

                    <TextBlock x:Name="SubtitleText"
                               Text="Authorize the desktop app using your browser"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </StackPanel>

                <!-- Auth code display -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center"
                            Margin="0,20,0,0">

                    <!-- Loading state -->
                    <StackPanel x:Name="LoadingPanel" Visibility="Visible">
                        <TextBlock Text="Generating code..."
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12"/>
                        <Ellipse Width="8" Height="8" Fill="{StaticResource BlueAccent}"
                                 HorizontalAlignment="Center" Opacity="0.4">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="Opacity"
                                                From="0.3" To="1"
                                Duration="0:0:0.8"
                                AutoReverse="True"
                                RepeatBehavior="Forever"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                    </StackPanel>

                    <!-- Auth code panel (shown after code is generated) -->
                    <StackPanel x:Name="CodePanel" Visibility="Collapsed">

                        <!-- Auth Code Display -->
                        <Border Background="{StaticResource BgDarker}"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="24,20"
                                Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="AUTH CODE"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="9" FontWeight="Bold"
                                           CharacterSpacing="200"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,12"/>

                                <TextBlock x:Name="AuthCodeText"
                                           Text="XXXX XXXX"
                                           Foreground="{StaticResource BlueAccent}"
                                           FontSize="32" FontWeight="Black"
                                           FontFamily="Consolas, Courier New, monospace"
                                           CharacterSpacing="600"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,12">
                                    <TextBlock.Effect>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="0"
                                                          Opacity="0.4" Color="#3b82f6"/>
                                    </TextBlock.Effect>
                                </TextBlock>

                                <TextBlock Text="Enter this code on the website"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="10"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- URL Display -->
                        <Border Background="{StaticResource BgDarker}"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="16,14"
                                Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Open this link in your browser"
                                               Foreground="{StaticResource TextMuted}"
                                               FontSize="9" FontWeight="Bold"
                                               CharacterSpacing="100"
                                               Margin="0,0,0,4"/>
                                    <TextBlock x:Name="UrlText"
                                               Text="thalamus.dev/auth/desktop"
                                               Foreground="{StaticResource BlueAccent}"
                                               FontSize="11"
                                               FontFamily="Consolas, Courier New, monospace"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap"/>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Content="Copy Link"
                                        Style="{StaticResource OutlineButton}"
                                        BorderBrush="{StaticResource BorderColor}"
                                        Width="80"
                                        FontSize="10"
                                        Click="CopyUrl_Click"/>
                            </Grid>
                        </Border>

                        <!-- Open in Browser Button -->
                        <Button x:Name="OpenBrowserBtn"
                                Content="🔗  Open in Browser & Authorize"
                                Style="{StaticResource GlowButton}"
                                Height="42"
                                FontSize="12"
                                Margin="0,0,0,16"
                                Click="OpenBrowser_Click"/>

                        <!-- Waiting for authorization -->
                        <Border x:Name="WaitingPanel"
                                Background="#0d1f3c"
                                BorderBrush="#1a3a5f"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="20,16"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="Waiting for authorization..."
                                           Foreground="{StaticResource BlueAccent}"
                                           FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8"/>

                                <TextBlock x:Name="PollingText"
                                           Text="Open the link in your browser and sign in"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="10"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Margin="0,0,0,4"/>

                                <!-- Animated dots -->
                                <TextBlock Text="..."
                                           Foreground="{StaticResource BlueAccent}"
                                           FontSize="20" FontWeight="Bold"
                                           HorizontalAlignment="Center">
                                    <TextBlock.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ObjectAnimationUsingKeyFrames
                                                        Storyboard.TargetProperty="(TextBlock.Text)"
                                                        Duration="0:0:2" RepeatBehavior="Forever">
                                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.0" Value=""/>
                                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.4" Value="."/>
                                                        <DiscreteObjectKeyFrame KeyTime="0:0:0.8" Value=".."/>
                                                        <DiscreteObjectKeyFrame KeyTime="0:0:1.2" Value="..."/>
                                                        <DiscreteObjectKeyFrame KeyTime="0:0:1.6" Value=".."/>
                                                        <DiscreteObjectKeyFrame KeyTime="0:0:2.0" Value="."/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </TextBlock.Triggers>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Success Panel -->
                        <Border x:Name="SuccessPanel"
                                Background="#0a1f14"
                                BorderBrush="#1a4a30"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="20,20"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="✓"
                                           Foreground="{StaticResource GreenAccent}"
                                           FontSize="36" FontWeight="Black"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="Authorized!"
                                           Foreground="{StaticResource GreenAccent}"
                                           FontSize="16" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Opening Thalamus..."
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="11"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Error Panel -->
                        <Border x:Name="ErrorPanel"
                                Background="#1f0a0a"
                                BorderBrush="#4a1a1a"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="20,16"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="Connection Error"
                                           Foreground="{StaticResource RedAccent}"
                                           FontSize="12" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,6"/>
                                <TextBlock x:Name="ErrorText"
                                           Text="Could not connect. Check your internet and try again."
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="10"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Margin="0,0,0,10"/>
                                <Button Content="Retry"
                                        Style="{StaticResource OutlineButton}"
                                        BorderBrush="{StaticResource RedAccent}"
                                        Foreground="{StaticResource RedAccent}"
                                        HorizontalAlignment="Center"
                                        Width="100"
                                        FontSize="10"
                                        Click="Retry_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Expired Panel -->
                        <Border x:Name="ExpiredPanel"
                                Background="#1a1a0a"
                                BorderBrush="#4a4a1a"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="20,16"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="Code Expired"
                                           Foreground="{StaticResource AmberAccent}"
                                           FontSize="12" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="The code has expired. Generate a new one."
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="10"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Margin="0,0,0,10"/>
                                <Button Content="Generate New Code"
                                        Style="{StaticResource GlowButton}"
                                        HorizontalAlignment="Center"
                                        Width="160"
                                        FontSize="10"
                                        Click="GenerateNewCode_Click"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- ═══ Footer ═══ -->
            <Border Grid.Row="2"
                    Background="{StaticResource BgDarker}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,16,16"
                    Padding="16,10">
                <TextBlock Text="// AUTHENTICATION_GATE v1.0"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="9"
                           FontFamily="Consolas, Courier New, monospace"
                           HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</Window>
