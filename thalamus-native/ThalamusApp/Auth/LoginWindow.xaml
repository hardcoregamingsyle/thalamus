<Window x:Class="ThalamusApp.Auth.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sign In — Thalamus AI"
        Width="520" Height="440"
        MinWidth="460" MinHeight="380"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#050a14"
        AllowsTransparency="False"
        Loaded="Window_Loaded"
        Closing="OnClosing">

    <Window.Resources>
        <!-- Color palette ─ matching website premium theme -->
        <Color x:Key="BgDeep">#050a14</Color>
        <Color x:Key="BgDarker">#020b1d</Color>
        <Color x:Key="BgCard">#0a1628</Color>
        <Color x:Key="BgHover">#162a4a</Color>
        <Color x:Key="BorderColor">#1e3a5f</Color>
        <Color x:Key="TextPrimary">#e2e8f0</Color>
        <Color x:Key="TextSecondary">#8899aa</Color>
        <Color x:Key="TextMuted">#3a506a</Color>
        <Color x:Key="BlueAccent">#3b82f6</Color>
        <Color x:Key="GreenAccent">#10b981</Color>
        <Color x:Key="RedAccent">#ef4444</Color>

        <SolidColorBrush x:Key="BgDeepBrush"      Color="{StaticResource BgDeep}"/>
        <SolidColorBrush x:Key="BgDarkerBrush"    Color="{StaticResource BgDarker}"/>
        <SolidColorBrush x:Key="BgCardBrush"      Color="{StaticResource BgCard}"/>
        <SolidColorBrush x:Key="BgHoverBrush"     Color="{StaticResource BgHover}"/>
        <SolidColorBrush x:Key="BorderBrush"      Color="{StaticResource BorderColor}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="TextMutedBrush"   Color="{StaticResource TextMuted}"/>
        <SolidColorBrush x:Key="BlueBrush"        Color="{StaticResource BlueAccent}"/>
        <SolidColorBrush x:Key="GreenBrush"       Color="{StaticResource GreenAccent}"/>
        <SolidColorBrush x:Key="RedBrush"         Color="{StaticResource RedAccent}"/>

        <LinearGradientBrush x:Key="BlueGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#3b82f6" Offset="0"/>
            <GradientStop Color="#6366f1" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="CardGlow" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#0f1f3a" Offset="0"/>
            <GradientStop Color="#0a1628" Offset="1"/>
        </LinearGradientBrush>

        <!-- Traffic light style -->
        <Style x:Key="TrafficLight" TargetType="Ellipse">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="StrokeThickness" Value="0.5"/>
        </Style>

        <!-- Close button -->
        <Style x:Key="CloseBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary action button -->
        <!-- Note: WPF Button has no CornerRadius property — corner radius is set directly
             on the Border inside the ControlTemplate instead of via TemplateBinding. -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BlueGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="220"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ghost button -->
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Property elements (RowDefinitions) MUST come before child content in XAML -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Background -->
        <Rectangle Fill="#050a14"/>

        <!-- Ambient glow -->
        <Rectangle HorizontalAlignment="Center" VerticalAlignment="Top"
                   Width="450" Height="350" Opacity="0.08">
            <Rectangle.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#3b82f6" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Subtle grid overlay -->
        <Rectangle Opacity="0.03">
            <Rectangle.Fill>
                <DrawingBrush Viewport="0,0,30,30" ViewportUnits="Absolute" TileMode="Tile">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing>
                            <GeometryDrawing.Geometry>
                                <RectangleGeometry Rect="0,0,30,30"/>
                            </GeometryDrawing.Geometry>
                            <GeometryDrawing.Pen>
                                <Pen Thickness="0.5" Brush="#3b82f6"/>
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- ═══ TITLE BAR (terminal style) ═══ -->
        <Border Grid.Row="0" Background="{StaticResource BgDarkerBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Ellipse Style="{StaticResource TrafficLight}" Fill="#ff5f57" Stroke="#e04844"/>
                    <Ellipse Style="{StaticResource TrafficLight}" Fill="#febc2e" Stroke="#dda020" Margin="8,0,0,0"/>
                    <Ellipse Style="{StaticResource TrafficLight}" Fill="#28c840" Stroke="#20a830" Margin="8,0,0,0"/>
                    <TextBlock Text="  thalamus://auth" FontSize="10" FontFamily="Consolas"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" Style="{StaticResource CloseBtn}"
                        Content="&#x2715;" Click="CloseBtn_Click"/>
            </Grid>
        </Border>

        <!-- ═══ CONTENT ═══ -->
        <Border Grid.Row="1" Padding="36,24,36,24">
            <Grid>
                <!-- ═══ LOADING STATE ═══ -->
                <StackPanel x:Name="LoadingPanel" VerticalAlignment="Center"
                            Visibility="Visible">
                    <!-- Logo -->
                    <Border Width="44" Height="44" CornerRadius="12"
                            Background="{StaticResource BlueGradient}"
                            HorizontalAlignment="Center" Margin="0,0,0,18">
                        <TextBlock Text="T" FontSize="20" FontWeight="Black"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Connecting to Thalamus..."
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="Generating secure authentication code"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,24"/>

                    <!-- Animated dots -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Ellipse x:Name="Dot1" Width="7" Height="7" Fill="{StaticResource BlueBrush}"
                                 Margin="0,0,5,0" Opacity="0.3"/>
                        <Ellipse x:Name="Dot2" Width="7" Height="7" Fill="{StaticResource BlueBrush}"
                                 Margin="5,0,5,0" Opacity="0.3"/>
                        <Ellipse x:Name="Dot3" Width="7" Height="7" Fill="{StaticResource BlueBrush}"
                                 Margin="5,0,0,0" Opacity="0.3"/>
                    </StackPanel>
                </StackPanel>

                <!-- ═══ AUTH CODE STATE ═══ -->
                <StackPanel x:Name="CodePanel" VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <!-- Title -->
                    <TextBlock Text="Authorize Desktop App"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="Enter this code on the website to sign in securely"
                               FontSize="10.5"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,0,0,24"/>

                    <!-- Auth code card -->
                    <Border CornerRadius="12"
                            Background="{StaticResource CardGlow}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="32,20"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,20">
                        <Border CornerRadius="8"
                                Background="#040916"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" Padding="24,16">
                            <TextBlock x:Name="CodeLabel"
                                       Text="XXXX XXXX"
                                       FontSize="38" FontWeight="Bold"
                                       FontFamily="Consolas"
                                       Foreground="{StaticResource BlueBrush}"
                                       HorizontalAlignment="Center"
                                       CharacterSpacing="8"/>
                        </Border>
                    </Border>

                    <!-- Open in Browser button -->
                    <Button x:Name="OpenBrowserBtn"
                            Style="{StaticResource PrimaryBtn}"
                            Click="OpenBrowser_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="&#x1F310;" FontSize="13" Margin="0,0,8,0"/>
                            <TextBlock Text="Open in Browser"/>
                        </StackPanel>
                    </Button>

                    <!-- Status text -->
                    <TextBlock x:Name="StatusLabel" Text="Waiting for authorization..."
                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,14,0,0"/>

                    <!-- Cancel button -->
                    <Button Content="Cancel" Style="{StaticResource GhostBtn}"
                            Width="100" Height="30" FontSize="10"
                            HorizontalAlignment="Center" Margin="0,10,0,0"
                            Click="CloseBtn_Click"/>
                </StackPanel>

                <!-- ═══ SUCCESS STATE ═══ -->
                <StackPanel x:Name="SuccessPanel" VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <!-- Green check circle -->
                    <Border Width="56" Height="56" CornerRadius="28"
                            Background="{StaticResource GreenBrush}"
                            HorizontalAlignment="Center" Margin="0,0,0,16">
                        <TextBlock Text="&#x2713;" FontSize="24" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Authorized!"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource GreenBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="You are now signed in to Thalamus."
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- ═══ ERROR STATE ═══ -->
                <StackPanel x:Name="ErrorPanel" VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <!-- Red X circle -->
                    <Border Width="56" Height="56" CornerRadius="28"
                            Background="{StaticResource RedBrush}"
                            HorizontalAlignment="Center" Margin="0,0,0,16">
                        <TextBlock Text="&#x2715;" FontSize="22" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="ErrorLabel" Text="Authorization failed"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource RedBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="The authorization code may have expired or an error occurred."
                               FontSize="10.5"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,0,0,20"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Try Again"
                                Style="{StaticResource PrimaryBtn}"
                                Width="130" Height="36" FontSize="11"
                                Click="Retry_Click"/>
                        <Button Content="Cancel"
                                Style="{StaticResource GhostBtn}"
                                Width="100" Height="36" FontSize="10"
                                Margin="10,0,0,0"
                                Click="CloseBtn_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
