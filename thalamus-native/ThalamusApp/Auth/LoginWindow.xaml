<Window x:Class="ThalamusApp.Auth.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thalamus AI — Sign In"
        Width="440" Height="540"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#050a14"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <SolidColorBrush x:Key="Bg"      Color="#050a14"/>
        <SolidColorBrush x:Key="BgCard"  Color="#0a1628"/>
        <SolidColorBrush x:Key="Border"  Color="#1e3a5f"/>
        <SolidColorBrush x:Key="Primary" Color="#3b82f6"/>
        <SolidColorBrush x:Key="TextPri" Color="#e2e8f0"/>
        <SolidColorBrush x:Key="TextSec" Color="#64748b"/>
        <SolidColorBrush x:Key="Red"     Color="#ef4444"/>

        <Style x:Key="Field" TargetType="TextBox">
            <Setter Property="Background"     Value="#0d1f3c"/>
            <Setter Property="Foreground"     Value="{StaticResource TextPri}"/>
            <Setter Property="BorderBrush"    Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"        Value="12,10"/>
            <Setter Property="FontSize"       Value="13"/>
            <Setter Property="CaretBrush"     Value="{StaticResource TextPri}"/>
        </Style>

        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="FontSize"       Value="14"/>
            <Setter Property="FontWeight"     Value="SemiBold"/>
            <Setter Property="Foreground"     Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="Height"         Value="44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{StaticResource Border}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#020b1d"
                    MouseLeftButtonDown="TitleBar_Drag">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                        <Border Width="16" Height="16" CornerRadius="4" Margin="0,0,8,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#3b82f6" Offset="0"/>
                                    <GradientStop Color="#6366f1" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="T" FontSize="9" FontWeight="Black" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Thalamus AI" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPri}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" Width="38" Height="28" Content="×" FontSize="16"
                            Background="Transparent" Foreground="{StaticResource TextSec}"
                            BorderThickness="0" Cursor="Hand" Click="CloseBtn_Click"/>
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="40,36,40,40" VerticalAlignment="Top">

                <!-- Logo -->
                <Border Width="60" Height="60" CornerRadius="18" HorizontalAlignment="Center" Margin="0,0,0,24">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1d4ed8" Offset="0"/>
                            <GradientStop Color="#6366f1" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="T" FontSize="30" FontWeight="Black" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock x:Name="HeadingLabel" Text="Sign in to Thalamus AI"
                           FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPri}"
                           HorizontalAlignment="Center" Margin="0,0,0,6"/>
                <TextBlock x:Name="SubLabel" Text="Enter your email to receive a login code"
                           FontSize="12" Foreground="{StaticResource TextSec}"
                           HorizontalAlignment="Center" Margin="0,0,0,28" TextWrapping="Wrap"
                           TextAlignment="Center"/>

                <!-- EMAIL SCREEN -->
                <StackPanel x:Name="EmailPanel">
                    <TextBlock Text="Email address" FontSize="12" Foreground="{StaticResource TextSec}" Margin="0,0,0,6"/>
                    <TextBox x:Name="EmailBox" Style="{StaticResource Field}"
                             KeyDown="Field_KeyDown"/>
                    <TextBlock x:Name="EmailError" Text="" Foreground="{StaticResource Red}"
                               FontSize="11" Margin="0,6,0,0" Visibility="Collapsed"/>
                    <Button x:Name="SendOtpBtn" Content="Send Login Code" Margin="0,18,0,0"
                            Click="SendOtp_Click">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#2563eb" Offset="0"/>
                                <GradientStop Color="#4f46e5" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </StackPanel>

                <!-- OTP SCREEN -->
                <StackPanel x:Name="OtpPanel" Visibility="Collapsed">
                    <TextBlock Text="6-digit code" FontSize="12" Foreground="{StaticResource TextSec}" Margin="0,0,0,6"/>
                    <TextBox x:Name="OtpBox" Style="{StaticResource Field}"
                             MaxLength="6" KeyDown="Field_KeyDown"/>
                    <TextBlock x:Name="OtpError" Text="" Foreground="{StaticResource Red}"
                               FontSize="11" Margin="0,6,0,0" Visibility="Collapsed"/>
                    <Button x:Name="VerifyBtn" Content="Verify &amp; Sign In" Margin="0,18,0,0"
                            Click="Verify_Click">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#2563eb" Offset="0"/>
                                <GradientStop Color="#4f46e5" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                    <Button Content="Back" Margin="0,10,0,0" Background="#0d1f3c"
                            Click="Back_Click"/>
                </StackPanel>

                <!-- Spinner / status -->
                <TextBlock x:Name="StatusLabel" Text="" FontSize="12"
                           Foreground="{StaticResource TextSec}" HorizontalAlignment="Center"
                           Margin="0,16,0,0" TextWrapping="Wrap" TextAlignment="Center"/>

            </StackPanel>
        </Grid>
    </Border>
</Window>
