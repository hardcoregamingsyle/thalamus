<Window x:Class="ThalamusApp.Auth.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sign In — Thalamus AI"
        Width="480" Height="340"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#050a14"
        AllowsTransparency="False"
        Loaded="Window_Loaded"
        Closing="OnClosing">

    <Window.Resources>
        <Color x:Key="BgDark">#050a14</Color>
        <Color x:Key="BgDarker">#020b1d</Color>
        <Color x:Key="BgCard">#0a1628</Color>
        <Color x:Key="BgHover">#1a2d4a</Color>
        <Color x:Key="BorderColor">#1e3a5f</Color>
        <Color x:Key="TextPrimary">#e2e8f0</Color>
        <Color x:Key="TextSecondary">#64748b</Color>
        <Color x:Key="BlueAccent">#3b82f6</Color>
        <Color x:Key="GreenAccent">#10b981</Color>
        <Color x:Key="RedAccent">#ef4444</Color>

        <SolidColorBrush x:Key="BgDarkBrush"   Color="{StaticResource BgDark}"/>
        <SolidColorBrush x:Key="BgDarkerBrush" Color="{StaticResource BgDarker}"/>
        <SolidColorBrush x:Key="BgCardBrush"   Color="{StaticResource BgCard}"/>
        <SolidColorBrush x:Key="BorderBrush"   Color="{StaticResource BorderColor}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="BlueBrush"     Color="{StaticResource BlueAccent}"/>
        <SolidColorBrush x:Key="GreenBrush"    Color="{StaticResource GreenAccent}"/>
        <SolidColorBrush x:Key="RedBrush"      Color="{StaticResource RedAccent}"/>

        <LinearGradientBrush x:Key="BlueGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#3b82f6" Offset="0"/>
            <GradientStop Color="#6366f1" Offset="1"/>
        </LinearGradientBrush>

        <!-- Title bar button -->
        <Style x:Key="TitleBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Background glow -->
        <Rectangle Fill="#050a14"/>
        <Rectangle HorizontalAlignment="Center" VerticalAlignment="Top"
                   Width="400" Height="300" Opacity="0.07">
            <Rectangle.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#3b82f6" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Grid.RowDefinitions>
            <RowDefinition Height="34"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ TITLE BAR ═══ -->
        <Border Grid.Row="0"
                Background="{StaticResource BgDarkerBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <TextBlock Text="Sign In — Thalamus AI"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center" Margin="14,0,0,0"/>
                <Button HorizontalAlignment="Right"
                        Style="{StaticResource TitleBtn}" Content="&#x2715;"
                        Click="CloseBtn_Click"/>
            </Grid>
        </Border>

        <!-- ═══ CONTENT ═══ -->
        <Border Grid.Row="1" Padding="32,28,32,24">
            <Grid>
                <!-- Loading state -->
                <StackPanel x:Name="LoadingPanel" VerticalAlignment="Center"
                            Visibility="Visible">
                    <TextBlock Text="Starting authorization..."
                               FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Ellipse Width="6" Height="6" Fill="{StaticResource BlueBrush}"
                                 Margin="0,0,4,0" RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform x:Name="Dot1Rotate"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <Ellipse Width="6" Height="6" Fill="{StaticResource BlueBrush}"
                                 Opacity="0.7" Margin="4,0,4,0" RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform x:Name="Dot2Rotate"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <Ellipse Width="6" Height="6" Fill="{StaticResource BlueBrush}"
                                 Opacity="0.4" Margin="4,0,0,0" RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform x:Name="Dot3Rotate"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </StackPanel>
                </StackPanel>

                <!-- Auth code display -->
                <StackPanel x:Name="CodePanel" VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="Authorize Desktop App"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,6"/>

                    <TextBlock Text="Enter this code on the website to sign in"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <!-- Auth code -->
                    <Border CornerRadius="10"
                            Background="{StaticResource BgCardBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="28,18"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,20">
                        <TextBlock x:Name="CodeLabel"
                                   Text="XXXX XXXX"
                                   FontSize="32" FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource BlueBrush}"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Open browser button -->
                    <Button x:Name="OpenBrowserBtn"
                            Height="40" Width="220"
                            CornerRadius="8"
                            Background="{StaticResource BlueGradient}"
                            Foreground="White"
                            FontSize="13" FontWeight="SemiBold"
                            BorderThickness="0"
                            Cursor="Hand"
                            HorizontalAlignment="Center"
                            Click="OpenBrowser_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="&#x1F310;" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Open in Browser"/>
                        </StackPanel>
                    </Button>

                    <TextBlock x:Name="StatusLabel" Text=""
                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                </StackPanel>

                <!-- Success state -->
                <StackPanel x:Name="SuccessPanel" VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <Ellipse Width="48" Height="48"
                             Fill="{StaticResource GreenBrush}"
                             HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="Authorized!"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource GreenBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="You are now signed in."
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Error state -->
                <StackPanel x:Name="ErrorPanel" VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <Ellipse Width="48" Height="48"
                             Fill="{StaticResource RedBrush}"
                             HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock x:Name="ErrorLabel" Text="Authorization failed"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource RedBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <Button Content="Try Again"
                            Height="36" Width="140"
                            CornerRadius="8"
                            Background="{StaticResource BgCardBrush}"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            FontSize="12"
                            Cursor="Hand"
                            HorizontalAlignment="Center"
                            Click="Retry_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
