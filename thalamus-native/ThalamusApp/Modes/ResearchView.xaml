<UserControl x:Class="ThalamusApp.Modes.ResearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:ThalamusApp.Controls"
             Background="#050a14" Foreground="#e2e8f0">

    <UserControl.Resources>
        <SolidColorBrush x:Key="BgDarker" Color="#020b1d"/>
        <SolidColorBrush x:Key="Border"   Color="#1e3a5f"/>
        <SolidColorBrush x:Key="Primary"  Color="#3b82f6"/>

        <Style x:Key="ConvBtn" TargetType="Button">
            <Setter Property="Background"             Value="Transparent"/>
            <Setter Property="Foreground"             Value="#94a3b8"/>
            <Setter Property="BorderThickness"        Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                Value="12,8"/>
            <Setter Property="Cursor"                 Value="Hand"/>
            <Setter Property="FontSize"               Value="12"/>
            <Setter Property="Margin"                 Value="4,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0d1f3c"/>
                                <Setter Property="Foreground" Value="#e2e8f0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NewConvBtn" TargetType="Button" BasedOn="{StaticResource ConvBtn}">
            <Setter Property="Foreground" Value="{StaticResource Primary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource BgDarker}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="12,14,12,10"
                        BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                    <Button x:Name="NewConvBtn" Content="+ New Research"
                            Style="{StaticResource NewConvBtn}" Click="NewConv_Click"/>
                </Border>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ConvList" Margin="6,8"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Main area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" x:Name="ChatScroll"
                          VerticalScrollBarVisibility="Auto" Padding="20,16">
                <StackPanel x:Name="MessageList"/>
            </ScrollViewer>

            <StackPanel x:Name="EmptyState" Grid.Row="0"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🔬" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,14"/>
                <TextBlock Text="Deep Research Mode"
                           FontSize="18" FontWeight="Bold" Foreground="#e2e8f0"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Ask a complex question for in-depth analysis"
                           FontSize="13" Foreground="#64748b"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>

            <Border Grid.Row="1" Background="{StaticResource BgDarker}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0"
                    Padding="20,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#0d1f3c"
                            BorderBrush="{StaticResource Border}" BorderThickness="1"
                            CornerRadius="10">
                        <TextBox x:Name="InputBox"
                                 Background="Transparent" Foreground="#e2e8f0"
                                 BorderThickness="0" Padding="14,10"
                                 FontSize="13" CaretBrush="#e2e8f0"
                                 AcceptsReturn="False" TextWrapping="Wrap"
                                 MaxHeight="120" VerticalScrollBarVisibility="Auto"
                                 KeyDown="Input_KeyDown"/>
                    </Border>

                    <Button Grid.Column="1" x:Name="SendBtn"
                            Width="44" Height="44" Margin="10,0,0,0"
                            Click="Send_Click" Cursor="Hand">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#2563eb" Offset="0"/>
                                <GradientStop Color="#4f46e5" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        CornerRadius="10">
                                    <TextBlock Text="↑" FontSize="18" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
