<UserControl x:Class="ThalamusApp.Modes.ResearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBgGradient}">

    <UserControl.Resources>
        <!-- ThinScrollBar, ThemedInput, ExampleChip etc. come from Styles/Theme.xaml -->

        <!-- Search button -->
        <Style x:Key="SearchBtn" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="10">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0088f1" Offset="0"/>
                                    <GradientStop Color="#0073d2" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#040b1e"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="22,0">
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="20" Height="20" CornerRadius="5" VerticalAlignment="Center" Margin="0,0,9,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#b45309" Offset="0"/>
                                    <GradientStop Color="#d97706" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Path Data="M21 21 L15 15 M17 11 A6 6 0 1 1 5 11 A6 6 0 0 1 17 11 Z"
                                  Stroke="White" StrokeThickness="1.5" StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" Width="10" Height="10" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Research" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Live web search with source citations"
                               FontSize="10.5" Foreground="{StaticResource TextMutedBrush}" Margin="29,2,0,0"/>
                </StackPanel>

                <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                        CornerRadius="6" Background="#1a1200"
                        BorderBrush="#3a2800" BorderThickness="1" Padding="10,4">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="5" Height="5"
                                 Fill="{StaticResource AmberBrush}"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="ResearchStatusLabel" Text="Ready"
                                   FontSize="9.5" FontFamily="{StaticResource MonoFontFamily}"
                                   Foreground="{StaticResource AmberBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ RESULTS AREA ═══ -->
        <Grid Grid.Row="1">
            <ScrollViewer x:Name="ResearchScroll"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="24,18,12,10">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBar}"/>
                </ScrollViewer.Resources>
                <StackPanel x:Name="ResearchPanel" MaxWidth="820" Margin="0,0,4,0">

                    <!-- Progress bar (hidden by default) -->
                    <Border x:Name="ProgressCard" Visibility="Collapsed"
                            Style="{StaticResource Card}" CornerRadius="12"
                            Padding="20,16" Margin="0,0,0,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock x:Name="ProgressStepLabel" Text="Searching the web…"
                                           FontSize="12" FontWeight="SemiBold"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <Border Height="3" CornerRadius="2" Background="#0d1f3c">
                                <Border x:Name="ProgressFill" Height="3" CornerRadius="2"
                                        HorizontalAlignment="Left" Width="0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#0088f1" Offset="0"/>
                                            <GradientStop Color="#0073d2" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Results (filled dynamically) -->
                </StackPanel>
            </ScrollViewer>

            <!-- ═══ EMPTY STATE ═══ -->
            <StackPanel x:Name="EmptyState" MaxWidth="440"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="0,0,0,32">
                <Border Width="52" Height="52" CornerRadius="14"
                        HorizontalAlignment="Center" Margin="0,0,0,18"
                        Background="#1a1200" BorderBrush="#3a2800" BorderThickness="1">
                    <Path Data="M21 21 L15 15 M17 11 A6 6 0 1 1 5 11 A6 6 0 0 1 17 11 Z"
                          Stroke="{StaticResource AmberBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round" Width="22" Height="22" Stretch="Uniform"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Search any topic." HorizontalAlignment="Center"
                           FontSize="13.5" Foreground="{StaticResource TextMutedBrush}"
                           Margin="0,0,0,22"/>
                <WrapPanel HorizontalAlignment="Center">
                    <Border Style="{StaticResource ExampleChip}" MouseLeftButtonDown="Example_Click">
                        <TextBlock Text="Latest AI model benchmarks" Style="{StaticResource ExampleChipText}"/>
                    </Border>
                    <Border Style="{StaticResource ExampleChip}" MouseLeftButtonDown="Example_Click">
                        <TextBlock Text="Best programming languages 2025" Style="{StaticResource ExampleChipText}"/>
                    </Border>
                    <Border Style="{StaticResource ExampleChip}" MouseLeftButtonDown="Example_Click">
                        <TextBlock Text="How does quantum computing work" Style="{StaticResource ExampleChipText}"/>
                    </Border>
                </WrapPanel>
            </StackPanel>
        </Grid>

        <!-- ═══ INPUT ═══ -->
        <Border Grid.Row="2" Background="#030912"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="20,12,20,16">
            <Grid MaxWidth="820">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <TextBox x:Name="ResearchInputBox"
                             Style="{StaticResource ThemedInput}"
                             Height="40"
                             KeyDown="ResearchInput_KeyDown"/>
                    <TextBlock Text="Search a topic, compare options, get a report…"
                               IsHitTestVisible="False" FontSize="12.5" Foreground="#3a4654"
                               Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=ResearchInputBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Button Grid.Column="2" x:Name="ResearchButton"
                        Style="{StaticResource SearchBtn}"
                        Foreground="White"
                        Click="Research_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M21 21 L15 15 M17 11 A6 6 0 1 1 5 11 A6 6 0 0 1 17 11 Z"
                              Stroke="White" StrokeThickness="1.8" StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" Width="13" Height="13" Stretch="Uniform"
                              Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Research" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
