<UserControl x:Class="ThalamusApp.Modes.CodeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBgGradient}">

    <UserControl.Resources>

        <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Track x:Name="PART_Track" IsDirectionReversed="true">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.LineUpCommand" Opacity="0" Height="0"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="#1e3a5f" CornerRadius="2" Opacity="0.7"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.LineDownCommand" Opacity="0" Height="0"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BuildBtn" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="10">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#059669" Offset="0"/>
                                    <GradientStop Color="#10b981" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CodeInputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#080f22"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource GreenBrush}"/>
            <Setter Property="BorderBrush" Value="#1e3a5f"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}" CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#10b981"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Agent stage pill -->
        <Style x:Key="AgentPill" TargetType="Border">
            <Setter Property="Background" Value="#080f22"/>
            <Setter Property="BorderBrush" Value="#1a3050"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#040b1e"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="22,0">
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="20" Height="20" CornerRadius="5" VerticalAlignment="Center" Margin="0,0,9,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#047857" Offset="0"/>
                                    <GradientStop Color="#10b981" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Path Data="M13 10V3L4 14h7v7l9-11h-7z"
                                  Fill="White" Width="10" Height="10" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Build" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <Border CornerRadius="8" Background="#061a10"
                                BorderBrush="#0a3018" BorderThickness="1"
                                Padding="7,2" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="9-Agent Pipeline" FontSize="8.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource GreenBrush}"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="Describe what you want to build and 9 agents build it in sequence"
                               FontSize="10.5" Foreground="{StaticResource TextSecondaryBrush}" Margin="29,2,0,0"/>
                </StackPanel>

                <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                        CornerRadius="6" Background="#061a10"
                        BorderBrush="#0a3018" BorderThickness="1" Padding="10,4">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="BuildStatusDot" Width="5" Height="5"
                                 Fill="{StaticResource GreenBrush}"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="BuildStatusLabel" Text="Ready"
                                   FontSize="9.5" Foreground="{StaticResource GreenBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ CONTENT AREA ═══ -->
        <ScrollViewer Grid.Row="1" x:Name="BuildScroll"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="22,16,6,8">
            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBar}"/>
            </ScrollViewer.Resources>

            <StackPanel x:Name="BuildPanel" Margin="0,0,12,0">

                <!-- Welcome card -->
                <Border x:Name="BuildWelcomeCard"
                        Background="#0a1628" BorderBrush="#1e3a5f" BorderThickness="1"
                        CornerRadius="14" Padding="28,22">
                    <StackPanel>
                        <Border Width="44" Height="44" CornerRadius="11"
                                HorizontalAlignment="Left" Margin="0,0,0,14">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#047857" Offset="0"/>
                                    <GradientStop Color="#10b981" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Path Data="M13 10V3L4 14h7v7l9-11h-7z"
                                  Fill="White" Width="20" Height="20" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Describe any software project"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" FontSize="12.5"
                                   Foreground="{StaticResource TextSecondaryBrush}" LineHeight="20"
                                   Margin="0,0,0,20">
                            Thalamus runs 9 specialized agents in sequence — Researcher, Analyser, Planner, Coder, Optimiser, Organizer, Tester, Hacker, and Critic — to build your project.
                        </TextBlock>

                        <!-- 9 agent badges -->
                        <WrapPanel Margin="0,0,0,20">
                            <Border Style="{StaticResource AgentPill}">
                                <TextBlock Text="1  Researcher" FontSize="10.5" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Border>
                            <Border Style="{StaticResource AgentPill}">
                                <TextBlock Text="2  Analyser" FontSize="10.5" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Border>
                            <Border Style="{StaticResource AgentPill}">
                                <TextBlock Text="3  Planner" FontSize="10.5" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Border>
                            <Border Style="{StaticResource AgentPill}">
                                <TextBlock Text="4  Coder" FontSize="10.5" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Border>
                            <Border Style="{StaticResource AgentPill}">
                                <TextBlock Text="5  Optimiser" FontSize="10.5" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Border>
                            <Border Style="{StaticResource AgentPill}" Margin="0,4,6,0">
                                <TextBlock Text="6  Organizer" FontSize="10.5" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Border>
                            <Border Style="{StaticResource AgentPill}" Margin="0,4,6,0">
                                <TextBlock Text="7  Tester" FontSize="10.5" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Border>
                            <Border Style="{StaticResource AgentPill}" Margin="0,4,6,0">
                                <TextBlock Text="8  Hacker" FontSize="10.5" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Border>
                            <Border Style="{StaticResource AgentPill}" Margin="0,4,6,0">
                                <TextBlock Text="9  Critic" FontSize="10.5" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Border>
                        </WrapPanel>

                        <!-- Example projects -->
                        <TextBlock Text="Example projects"
                                   FontSize="10.5" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,0,0,10"/>
                        <WrapPanel>
                            <Border Background="#061a10" BorderBrush="#0a3018" BorderThickness="1"
                                    CornerRadius="7" Padding="10,6" Margin="0,0,8,8" Cursor="Hand"
                                    MouseLeftButtonDown="BuildExample_Click">
                                <TextBlock Text="REST API with auth" FontSize="11.5"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Border>
                            <Border Background="#061a10" BorderBrush="#0a3018" BorderThickness="1"
                                    CornerRadius="7" Padding="10,6" Margin="0,0,8,8" Cursor="Hand"
                                    MouseLeftButtonDown="BuildExample_Click">
                                <TextBlock Text="React dashboard with charts" FontSize="11.5"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Border>
                            <Border Background="#061a10" BorderBrush="#0a3018" BorderThickness="1"
                                    CornerRadius="7" Padding="10,6" Margin="0,0,8,8" Cursor="Hand"
                                    MouseLeftButtonDown="BuildExample_Click">
                                <TextBlock Text="Python data pipeline" FontSize="11.5"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Agent pipeline progress (hidden initially) -->
                <Border x:Name="AgentProgressCard" Visibility="Collapsed"
                        Background="#080f22" BorderBrush="#0a3018" BorderThickness="1"
                        CornerRadius="12" Padding="18,14" Margin="0,16,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="Pipeline Running" FontSize="11.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource GreenBrush}" Margin="0,0,10,0"/>
                            <TextBlock x:Name="AgentStageLabel" Text="Initializing…"
                                       FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <!-- Stage dots -->
                        <ItemsControl x:Name="AgentDots">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Output messages populate here -->
            </StackPanel>
        </ScrollViewer>

        <!-- ═══ INPUT ═══ -->
        <Border Grid.Row="2" Background="#030912"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="20,12,20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <TextBox x:Name="BuildInputBox"
                             Style="{StaticResource CodeInputStyle}"
                             Height="40"
                             KeyDown="BuildInput_KeyDown"/>
                    <TextBlock Text="Describe your project in plain English…"
                               IsHitTestVisible="False" FontSize="12.5" Foreground="#1e3828"
                               Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=BuildInputBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Button Grid.Column="2" x:Name="BuildButton"
                        Style="{StaticResource BuildBtn}"
                        Foreground="White"
                        Click="Build_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M13 10V3L4 14h7v7l9-11h-7z"
                              Fill="White" Width="13" Height="13" Stretch="Uniform"
                              Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Build" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
