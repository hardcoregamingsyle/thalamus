<UserControl x:Class="ThalamusApp.Modes.CodeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBgGradient}">

    <UserControl.Resources>
        <!-- ThinScrollBar, Card, ExampleChip etc. come from Styles/Theme.xaml -->

        <Style x:Key="BuildBtn" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="10">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#059669" Offset="0"/>
                                    <GradientStop Color="#10b981" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Shared ThemedInput with the Build mode's green caret/focus accent -->
        <Style x:Key="CodeInputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgInputBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource GreenBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}" CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource GreenBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#040b1e"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="22,0">
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="20" Height="20" CornerRadius="5" VerticalAlignment="Center" Margin="0,0,9,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#047857" Offset="0"/>
                                    <GradientStop Color="#10b981" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Path Data="M13 10V3L4 14h7v7l9-11h-7z"
                                  Fill="White" Width="10" Height="10" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Build" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <Border CornerRadius="8" Background="#061a10"
                                BorderBrush="#0a3018" BorderThickness="1"
                                Padding="7,2" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="9-Agent Pipeline" FontSize="8.5" FontWeight="SemiBold"
                                       FontFamily="{StaticResource MonoFontFamily}"
                                       Foreground="{StaticResource GreenBrush}"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="Describe a project — 9 agents build it in sequence"
                               FontSize="10.5" Foreground="{StaticResource TextMutedBrush}" Margin="29,2,0,0"/>
                </StackPanel>

                <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                        CornerRadius="6" Background="#061a10"
                        BorderBrush="#0a3018" BorderThickness="1" Padding="10,4">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="BuildStatusDot" Width="5" Height="5"
                                 Fill="{StaticResource GreenBrush}"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="BuildStatusLabel" Text="Ready"
                                   FontSize="9.5" FontFamily="{StaticResource MonoFontFamily}"
                                   Foreground="{StaticResource GreenBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ CONTENT AREA ═══ -->
        <Grid Grid.Row="1">
            <ScrollViewer x:Name="BuildScroll"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="24,18,12,10">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBar}"/>
                </ScrollViewer.Resources>

                <StackPanel x:Name="BuildPanel" MaxWidth="820" Margin="0,0,4,0">

                    <!-- Agent pipeline progress (hidden initially) -->
                    <Border x:Name="AgentProgressCard" Visibility="Collapsed"
                            Background="#080f22" BorderBrush="#0a3018" BorderThickness="1"
                            CornerRadius="12" Padding="18,14" Margin="0,0,0,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="Pipeline Running" FontSize="11.5" FontWeight="SemiBold"
                                           Foreground="{StaticResource GreenBrush}" Margin="0,0,10,0"/>
                                <TextBlock x:Name="AgentStageLabel" Text="Initializing…"
                                           FontSize="11.5" FontFamily="{StaticResource MonoFontFamily}"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <!-- Stage dots -->
                            <ItemsControl x:Name="AgentDots">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Output messages populate here -->
                </StackPanel>
            </ScrollViewer>

            <!-- ═══ EMPTY STATE ═══ -->
            <StackPanel x:Name="EmptyState" MaxWidth="460"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="0,0,0,32">
                <Border Width="52" Height="52" CornerRadius="14"
                        HorizontalAlignment="Center" Margin="0,0,0,18"
                        Background="#061a10" BorderBrush="#0a3018" BorderThickness="1">
                    <Path Data="M13 10V3L4 14h7v7l9-11h-7z"
                          Fill="{StaticResource GreenBrush}" Width="22" Height="22" Stretch="Uniform"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Describe something to build." HorizontalAlignment="Center"
                           FontSize="13.5" Foreground="{StaticResource TextMutedBrush}"
                           Margin="0,0,0,22"/>
                <WrapPanel HorizontalAlignment="Center">
                    <Border Style="{StaticResource ExampleChip}" MouseLeftButtonDown="BuildExample_Click">
                        <TextBlock Text="Build a REST API with JWT auth" Style="{StaticResource ExampleChipText}"/>
                    </Border>
                    <Border Style="{StaticResource ExampleChip}" MouseLeftButtonDown="BuildExample_Click">
                        <TextBlock Text="Build a React dashboard with charts" Style="{StaticResource ExampleChipText}"/>
                    </Border>
                    <Border Style="{StaticResource ExampleChip}" MouseLeftButtonDown="BuildExample_Click">
                        <TextBlock Text="Build a Python data pipeline" Style="{StaticResource ExampleChipText}"/>
                    </Border>
                </WrapPanel>
            </StackPanel>
        </Grid>

        <!-- ═══ INPUT ═══ -->
        <Border Grid.Row="2" Background="#030912"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="20,12,20,16">
            <Grid MaxWidth="820">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <TextBox x:Name="BuildInputBox"
                             Style="{StaticResource CodeInputStyle}"
                             Height="40"
                             KeyDown="BuildInput_KeyDown"/>
                    <TextBlock Text="Describe your project in plain English…"
                               IsHitTestVisible="False" FontSize="12.5" Foreground="#3a4654"
                               Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=BuildInputBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Button Grid.Column="2" x:Name="BuildButton"
                        Style="{StaticResource BuildBtn}"
                        Foreground="White"
                        Click="Build_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M13 10V3L4 14h7v7l9-11h-7z"
                              Fill="White" Width="13" Height="13" Stretch="Uniform"
                              Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Build" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
