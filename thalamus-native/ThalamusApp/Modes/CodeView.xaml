<UserControl x:Class="ThalamusApp.Modes.CodeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ThalamusApp"
             Background="#050a14" Foreground="#e2e8f0">

    <UserControl.Resources>
        <SolidColorBrush x:Key="BgDarker" Color="#020b1d"/>
        <SolidColorBrush x:Key="BgPanel"  Color="#0a1628"/>
        <SolidColorBrush x:Key="Border"   Color="#1e3a5f"/>
        <SolidColorBrush x:Key="Primary"  Color="#3b82f6"/>

        <Style x:Key="SideBtn" TargetType="Button">
            <Setter Property="Background"             Value="Transparent"/>
            <Setter Property="Foreground"             Value="#94a3b8"/>
            <Setter Property="BorderThickness"        Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                Value="12,8"/>
            <Setter Property="Cursor"                 Value="Hand"/>
            <Setter Property="FontSize"               Value="12"/>
            <Setter Property="Margin"                 Value="4,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0d1f3c"/>
                                <Setter Property="Foreground" Value="#e2e8f0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NewBtn" TargetType="Button" BasedOn="{StaticResource SideBtn}">
            <Setter Property="Foreground" Value="{StaticResource Primary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="AgentTag" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── SIDEBAR: project + branch list ── -->
        <Border Grid.Column="0" Background="{StaticResource BgDarker}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="12,14,12,10"
                        BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                    <Button x:Name="NewProjectBtn" Content="+ New Project"
                            Style="{StaticResource NewBtn}" Click="NewProject_Click"/>
                </Border>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ProjectList" Margin="6,8"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ── MAIN: agent feed + sandbox ── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="200"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="300" MinHeight="180"/>
            </Grid.RowDefinitions>

            <!-- Agent message feed (top half) -->
            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Branch header -->
                <Border Grid.Row="0" Background="{StaticResource BgDarker}"
                        BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                        Padding="16,10">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="BranchLabel" Text="No project selected"
                                       FontSize="13" FontWeight="SemiBold" Foreground="#e2e8f0"/>
                            <Border x:Name="StatusBadge" Margin="10,0,0,0"
                                    CornerRadius="4" Padding="8,2"
                                    Background="#0d1f3c" Visibility="Collapsed">
                                <TextBlock x:Name="StatusText" FontSize="10" FontWeight="Bold"
                                           Foreground="#3b82f6"/>
                            </Border>
                        </StackPanel>
                        <Button x:Name="RunAgentsBtn" Content="Run Agents" HorizontalAlignment="Right"
                                Click="RunAgents_Click" IsEnabled="False"
                                Foreground="White" FontSize="12" FontWeight="SemiBold"
                                BorderThickness="0" Cursor="Hand" Padding="14,6">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#2563eb" Offset="0"/>
                                    <GradientStop Color="#4f46e5" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            CornerRadius="7" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- Messages -->
                <ScrollViewer Grid.Row="1" x:Name="AgentScroll"
                              VerticalScrollBarVisibility="Auto" Padding="16,10">
                    <StackPanel x:Name="AgentMessageList"/>
                </ScrollViewer>

                <!-- Empty state -->
                <StackPanel x:Name="CodeEmptyState" Grid.Row="1"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="⚡" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Code Mode" FontSize="16" FontWeight="Bold"
                               Foreground="#e2e8f0" HorizontalAlignment="Center"/>
                    <TextBlock Text="Select or create a project to get started"
                               FontSize="12" Foreground="#64748b"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Input row -->
                <Border Grid.Row="2" Background="{StaticResource BgDarker}"
                        BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0"
                        Padding="16,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#0d1f3c"
                                BorderBrush="{StaticResource Border}" BorderThickness="1"
                                CornerRadius="8">
                            <TextBox x:Name="CodeInputBox"
                                     Background="Transparent" Foreground="#e2e8f0"
                                     BorderThickness="0" Padding="12,8"
                                     FontSize="13" CaretBrush="#e2e8f0"
                                     AcceptsReturn="False" TextWrapping="Wrap"
                                     MaxHeight="90" VerticalScrollBarVisibility="Auto"
                                     KeyDown="CodeInput_KeyDown"
                                     IsEnabled="False"/>
                        </Border>
                        <Button Grid.Column="1" x:Name="CodeSendBtn"
                                Width="40" Height="40" Margin="8,0,0,0"
                                Click="CodeSend_Click" Cursor="Hand" IsEnabled="False">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#2563eb" Offset="0"/>
                                    <GradientStop Color="#4f46e5" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8">
                                        <TextBlock Text="↑" FontSize="16" FontWeight="Bold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
            </Grid>

            <!-- Drag splitter -->
            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                          Background="{StaticResource Border}" Cursor="SizeNS"
                          ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"/>

            <!-- Sandbox (bottom half) -->
            <Border Grid.Row="2" Background="{StaticResource BgDarker}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
                <local:SandboxView x:Name="Sandbox"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
