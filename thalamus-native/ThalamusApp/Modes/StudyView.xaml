<UserControl x:Class="ThalamusApp.Modes.StudyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#050a14" Foreground="#e2e8f0">

    <UserControl.Resources>
        <SolidColorBrush x:Key="BgDarker" Color="#020b1d"/>
        <SolidColorBrush x:Key="BgPanel"  Color="#0a1628"/>
        <SolidColorBrush x:Key="Border"   Color="#1e3a5f"/>
        <SolidColorBrush x:Key="Primary"  Color="#3b82f6"/>

        <Style x:Key="DeckBtn" TargetType="Button">
            <Setter Property="Background"             Value="Transparent"/>
            <Setter Property="Foreground"             Value="#94a3b8"/>
            <Setter Property="BorderThickness"        Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                Value="12,9"/>
            <Setter Property="Cursor"                 Value="Hand"/>
            <Setter Property="FontSize"               Value="12"/>
            <Setter Property="Margin"                 Value="4,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0d1f3c"/>
                                <Setter Property="Foreground" Value="#e2e8f0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar: deck list -->
        <Border Grid.Column="0" Background="{StaticResource BgDarker}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="14,14,14,10"
                        BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                    <TextBlock Text="Study Decks" FontSize="12" FontWeight="SemiBold"
                               Foreground="#64748b"/>
                </Border>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DeckList" Margin="6,8"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Main: flashcard + quiz area -->
        <Grid Grid.Column="1">

            <!-- Empty state (no deck selected) -->
            <StackPanel x:Name="EmptyState"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="📚" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,14"/>
                <TextBlock Text="Study Mode" FontSize="18" FontWeight="Bold"
                           Foreground="#e2e8f0" HorizontalAlignment="Center"/>
                <TextBlock Text="Select a deck from the sidebar to begin"
                           FontSize="13" Foreground="#64748b"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>

            <!-- Flashcard panel -->
            <StackPanel x:Name="CardPanel" Visibility="Collapsed"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Width="520">

                <!-- Deck title -->
                <TextBlock x:Name="DeckTitle" FontSize="14" FontWeight="SemiBold"
                           Foreground="#64748b" HorizontalAlignment="Center" Margin="0,0,0,16"/>

                <!-- Progress -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <TextBlock x:Name="CardCounter" Text="Card 1 / 10"
                               FontSize="12" Foreground="#475569"/>
                </StackPanel>

                <!-- Flashcard (flip on click) -->
                <Border x:Name="CardBorder" Height="260"
                        Background="{StaticResource BgPanel}"
                        BorderBrush="{StaticResource Border}" BorderThickness="1"
                        CornerRadius="16" Cursor="Hand"
                        MouseLeftButtonDown="Card_Click">
                    <Grid>
                        <!-- Front (question) -->
                        <StackPanel x:Name="CardFront" VerticalAlignment="Center" Margin="36,24">
                            <TextBlock Text="QUESTION" FontSize="10" FontWeight="Bold"
                                       Foreground="#3b82f6" Margin="0,0,0,12"/>
                            <TextBlock x:Name="QuestionText" FontSize="15" Foreground="#e2e8f0"
                                       TextWrapping="Wrap" TextAlignment="Center"/>
                        </StackPanel>
                        <!-- Back (answer) -->
                        <StackPanel x:Name="CardBack" VerticalAlignment="Center" Margin="36,24"
                                    Visibility="Collapsed">
                            <TextBlock Text="ANSWER" FontSize="10" FontWeight="Bold"
                                       Foreground="#10b981" Margin="0,0,0,12"/>
                            <TextBlock x:Name="AnswerText" FontSize="14" Foreground="#cbd5e1"
                                       TextWrapping="Wrap" TextAlignment="Center"/>
                        </StackPanel>
                        <!-- Flip hint -->
                        <TextBlock x:Name="FlipHint" Text="Click to reveal answer"
                                   FontSize="11" Foreground="#334155"
                                   HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                   Margin="0,0,0,14"/>
                    </Grid>
                </Border>

                <!-- Nav buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button x:Name="PrevBtn" Content="← Prev" Click="Prev_Click"
                            Style="{StaticResource ActionBtn}" Background="#0d1f3c"
                            Margin="0,0,10,0" IsEnabled="False"/>
                    <Button x:Name="NextBtn" Content="Next →" Click="Next_Click"
                            Style="{StaticResource ActionBtn}">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#2563eb" Offset="0"/>
                                <GradientStop Color="#4f46e5" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </StackPanel>

                <!-- Generate quiz -->
                <Button x:Name="QuizBtn" Content="Generate Quiz" Margin="0,24,0,0"
                        Click="GenerateQuiz_Click" Style="{StaticResource ActionBtn}"
                        Background="#0f3460"/>

                <!-- Quiz result area -->
                <Border x:Name="QuizArea" Visibility="Collapsed" Margin="0,20,0,0"
                        Background="{StaticResource BgPanel}"
                        BorderBrush="{StaticResource Border}" BorderThickness="1"
                        CornerRadius="10" Padding="16,14">
                    <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="QuizText" Foreground="#e2e8f0" FontSize="13"
                                   TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Border>
            </StackPanel>

        </Grid>
    </Grid>
</UserControl>
