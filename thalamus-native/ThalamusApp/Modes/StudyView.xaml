<UserControl x:Class="ThalamusApp.Modes.StudyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBgGradient}">

    <UserControl.Resources>
        <!-- ThinScrollBar, Card, ExampleChip etc. come from Styles/Theme.xaml -->

        <Style x:Key="StudyBtn" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="10">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#4338ca" Offset="0"/>
                                    <GradientStop Color="#0073d2" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Shared ThemedInput with the Study mode's purple caret/focus accent -->
        <Style x:Key="StudyInputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgInputBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource PurpleBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}" CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource PurpleBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModeToggleBtn" TargetType="Button">
            <Setter Property="Background" Value="#0d1f3c"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="#1a3050"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="11,0"/>
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="13"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1a2a48"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModeToggleBtnActive" TargetType="Button" BasedOn="{StaticResource ModeToggleBtn}">
            <Setter Property="Foreground" Value="{StaticResource PurpleBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="13" BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1e1048" Offset="0"/>
                                    <GradientStop Color="#160d3c" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#8b5cf6" Offset="0"/>
                                    <GradientStop Color="#0073d2" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#040b1e"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="22,0">
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="20" Height="20" CornerRadius="5" VerticalAlignment="Center" Margin="0,0,9,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#4338ca" Offset="0"/>
                                    <GradientStop Color="#8b5cf6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Path Data="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"
                                  Stroke="White" StrokeThickness="1.4" StrokeLineJoin="Round"
                                  Fill="Transparent" Width="10" Height="10" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Study" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Explanations, quizzes, and step-by-step solutions"
                               FontSize="10.5" Foreground="{StaticResource TextMutedBrush}" Margin="29,2,0,0"/>
                </StackPanel>

                <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                        CornerRadius="6" Background="#12082a"
                        BorderBrush="#280e50" BorderThickness="1" Padding="10,4">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="5" Height="5"
                                 Fill="{StaticResource PurpleBrush}"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="StudyStatusLabel" Text="Ready"
                                   FontSize="9.5" FontFamily="{StaticResource MonoFontFamily}"
                                   Foreground="{StaticResource PurpleBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ MODE TOGGLES ═══ -->
        <Border Grid.Row="1" Background="#030912"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="18,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="TBtn_Tutor" Style="{StaticResource ModeToggleBtnActive}"
                        Click="StudyMode_Click" Tag="tutor" Margin="0,0,6,0">
                    <TextBlock Text="Tutor" FontSize="10.5"/>
                </Button>
                <Button x:Name="TBtn_Quiz" Style="{StaticResource ModeToggleBtn}"
                        Click="StudyMode_Click" Tag="quiz" Margin="0,0,6,0">
                    <TextBlock Text="Quiz Me" FontSize="10.5"/>
                </Button>
                <Button x:Name="TBtn_Solve" Style="{StaticResource ModeToggleBtn}"
                        Click="StudyMode_Click" Tag="solve" Margin="0,0,6,0">
                    <TextBlock Text="Step-by-Step Solve" FontSize="10.5"/>
                </Button>
                <Button x:Name="TBtn_Summary" Style="{StaticResource ModeToggleBtn}"
                        Click="StudyMode_Click" Tag="summary">
                    <TextBlock Text="Summarise" FontSize="10.5"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- ═══ MESSAGES ═══ -->
        <Grid Grid.Row="2">
            <ScrollViewer x:Name="StudyScroll"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="24,18,12,10">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBar}"/>
                </ScrollViewer.Resources>
                <StackPanel x:Name="StudyPanel" MaxWidth="820" Margin="0,0,4,0">

                    <!-- Typing indicator (no avatar, left-aligned dots) -->
                    <StackPanel x:Name="StudyTypingRow" Orientation="Horizontal"
                                Visibility="Collapsed" Margin="2,4,0,16">
                        <Ellipse Width="6" Height="6" Fill="{StaticResource PurpleBrush}" Margin="0,0,4,0">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0.3" To="1" Duration="0:0:0.5" AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <Ellipse Width="6" Height="6" Fill="{StaticResource PurpleBrush}" Margin="0,0,4,0" Opacity="0.3">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.17">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0.3" To="1" Duration="0:0:0.5" AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <Ellipse Width="6" Height="6" Fill="{StaticResource PurpleBrush}" Opacity="0.3">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.34">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0.3" To="1" Duration="0:0:0.5" AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- ═══ EMPTY STATE ═══ -->
            <StackPanel x:Name="EmptyState" MaxWidth="460"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="0,0,0,32">
                <Border Width="52" Height="52" CornerRadius="14"
                        HorizontalAlignment="Center" Margin="0,0,0,18"
                        Background="#12082a" BorderBrush="#280e50" BorderThickness="1">
                    <Path Data="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"
                          Stroke="{StaticResource PurpleBrush}" StrokeThickness="1.4" StrokeLineJoin="Round"
                          Fill="Transparent" Width="22" Height="22" Stretch="Uniform"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Learn anything, step by step." HorizontalAlignment="Center"
                           FontSize="13.5" Foreground="{StaticResource TextMutedBrush}"
                           Margin="0,0,0,22"/>
                <WrapPanel HorizontalAlignment="Center">
                    <Border Style="{StaticResource ExampleChip}" MouseLeftButtonDown="StudyExample_Click">
                        <TextBlock Text="Explain the basics of calculus" Style="{StaticResource ExampleChipText}"/>
                    </Border>
                    <Border Style="{StaticResource ExampleChip}" MouseLeftButtonDown="StudyExample_Click">
                        <TextBlock Text="Quiz me on world history" Style="{StaticResource ExampleChipText}"/>
                    </Border>
                    <Border Style="{StaticResource ExampleChip}" MouseLeftButtonDown="StudyExample_Click">
                        <TextBlock Text="Solve a physics problem step by step" Style="{StaticResource ExampleChipText}"/>
                    </Border>
                    <Border Style="{StaticResource ExampleChip}" MouseLeftButtonDown="StudyExample_Click">
                        <TextBlock Text="Summarize photosynthesis" Style="{StaticResource ExampleChipText}"/>
                    </Border>
                </WrapPanel>
            </StackPanel>
        </Grid>

        <!-- ═══ INPUT ═══ -->
        <Border Grid.Row="3" Background="#030912"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="20,12,20,16">
            <Grid MaxWidth="820">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <TextBox x:Name="StudyInputBox"
                             Style="{StaticResource StudyInputStyle}"
                             Height="40"
                             KeyDown="StudyInput_KeyDown"/>
                    <TextBlock x:Name="StudyPlaceholder" Text="Ask a question, share what you're learning…"
                               IsHitTestVisible="False" FontSize="12.5" Foreground="#3a4654"
                               Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=StudyInputBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Button Grid.Column="2" x:Name="StudyButton"
                        Style="{StaticResource StudyBtn}"
                        Foreground="White"
                        Click="Study_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M22 2L11 13 M22 2L15 22 9 13 2 9 22 2"
                              Stroke="White" StrokeThickness="1.7" StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" Width="14" Height="14" Stretch="Uniform"
                              Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Ask" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
