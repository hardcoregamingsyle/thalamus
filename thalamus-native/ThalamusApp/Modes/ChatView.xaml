<UserControl x:Class="ThalamusApp.Modes.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ContentBgGradient}">

    <UserControl.Resources>
        <!-- ThinScrollBar, ThemedInput, ExampleChip etc. come from Styles/Theme.xaml -->

        <!-- Send button -->
        <Style x:Key="SendBtn" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="10" Background="{DynamicResource BlueGradient}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>   <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Messages -->
            <RowDefinition Height="Auto"/> <!-- Input -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBgBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="22,0">
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="20" Height="20" CornerRadius="5"
                                Margin="0,0,9,0" VerticalAlignment="Center"
                                Background="{DynamicResource BlueGradient}">
                            <Path Data="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                                  Stroke="White" StrokeThickness="1.6" Fill="Transparent"
                                  Width="10" Height="10" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Chat" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Ask anything — clear, accurate answers"
                               FontSize="10.5" Foreground="{DynamicResource TextMutedBrush}"
                               Margin="29,2,0,0"/>
                </StackPanel>

                <!-- Status pill -->
                <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                        CornerRadius="6" Background="{DynamicResource TintBlueBgBrush}"
                        BorderBrush="{DynamicResource TintBlueBorderBrush}" BorderThickness="1" Padding="10,4">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="5" Height="5" Fill="{DynamicResource GreenBrush}"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="ChatCreditsLabel" Text="Ready"
                                   FontSize="9.5" FontFamily="{StaticResource MonoFontFamily}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ MESSAGES ═══ -->
        <Grid Grid.Row="1">
            <ScrollViewer x:Name="MessagesScroll"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="24,18,12,10">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBar}"/>
                </ScrollViewer.Resources>
                <!-- Bounded, centered conversation column (mirrors the site's max-w-4xl) -->
                <StackPanel x:Name="MessagesPanel" MaxWidth="820" Margin="0,0,4,0">

                    <!-- Typing indicator (no avatar, left-aligned dots) -->
                    <StackPanel x:Name="TypingRow" Orientation="Horizontal"
                                Visibility="Collapsed" Margin="2,4,0,16">
                        <Ellipse Width="6" Height="6" Fill="{DynamicResource TextMutedBrush}" Margin="0,0,4,0">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0.3" To="1" Duration="0:0:0.5"
                                                             AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <Ellipse Width="6" Height="6" Fill="{DynamicResource TextMutedBrush}" Margin="0,0,4,0" Opacity="0.3">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.17">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0.3" To="1" Duration="0:0:0.5"
                                                             AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <Ellipse Width="6" Height="6" Fill="{DynamicResource TextMutedBrush}" Opacity="0.3">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.34">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0.3" To="1" Duration="0:0:0.5"
                                                             AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- ═══ EMPTY STATE — centered icon + one line + prompt chips ═══ -->
            <StackPanel x:Name="EmptyState" MaxWidth="440"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="0,0,0,32">
                <Border Width="52" Height="52" CornerRadius="14"
                        HorizontalAlignment="Center" Margin="0,0,0,18"
                        Background="{DynamicResource TintBlueBgBrush}" BorderBrush="{DynamicResource TintBlueBorderBrush}" BorderThickness="1">
                    <Path Data="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                          Stroke="{DynamicResource BlueBrush}" StrokeThickness="1.6" Fill="Transparent"
                          Width="22" Height="22" Stretch="Uniform"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Ask anything." HorizontalAlignment="Center"
                           FontSize="13.5" Foreground="{DynamicResource TextMutedBrush}"
                           Margin="0,0,0,22"/>
                <WrapPanel HorizontalAlignment="Center">
                    <Border Style="{StaticResource ExampleChip}" MouseLeftButtonDown="Example_Click">
                        <TextBlock Text="Explain a concept simply" Style="{StaticResource ExampleChipText}"/>
                    </Border>
                    <Border Style="{StaticResource ExampleChip}" MouseLeftButtonDown="Example_Click">
                        <TextBlock Text="Draft a professional email" Style="{StaticResource ExampleChipText}"/>
                    </Border>
                    <Border Style="{StaticResource ExampleChip}" MouseLeftButtonDown="Example_Click">
                        <TextBlock Text="Debug a code snippet" Style="{StaticResource ExampleChipText}"/>
                    </Border>
                    <Border Style="{StaticResource ExampleChip}" MouseLeftButtonDown="Example_Click">
                        <TextBlock Text="Plan my week" Style="{StaticResource ExampleChipText}"/>
                    </Border>
                </WrapPanel>
            </StackPanel>
        </Grid>

        <!-- ═══ INPUT AREA ═══ -->
        <Border Grid.Row="2" Background="{DynamicResource InputBarBgBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="20,12,20,16">
            <Grid MaxWidth="820">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <TextBox x:Name="ChatInputBox"
                             Style="{StaticResource ThemedInput}"
                             Height="40"
                             KeyDown="ChatInput_KeyDown"/>
                    <TextBlock Text="Ask anything…"
                               IsHitTestVisible="False"
                               FontSize="13" Foreground="{DynamicResource InputPlaceholderBrush}"
                               Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=ChatInputBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Button Grid.Column="2" x:Name="SendButton"
                        Style="{StaticResource SendBtn}" Click="Send_Click">
                    <Path Data="M22 2L11 13 M22 2L15 22 9 13 2 9 22 2"
                          Stroke="White" StrokeThickness="1.7"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Width="15" Height="15" Stretch="Uniform"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
