<UserControl x:Class="ThalamusApp.Modes.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBgGradient}">

    <UserControl.Resources>
        <!-- ThinScrollBar, ThemedInput, Card etc. come from Styles/Theme.xaml -->

        <!-- Send button -->
        <Style x:Key="SendBtn" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="10">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#3b82f6" Offset="0"/>
                                    <GradientStop Color="#6366f1" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Model pill -->
        <Style x:Key="ModelPill" TargetType="Button">
            <Setter Property="Background" Value="#0d1f3c"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="#1a3050"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="11,0"/>
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="13"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#162a4a"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModelPillActive" TargetType="Button" BasedOn="{StaticResource ModelPill}">
            <Setter Property="Foreground" Value="{StaticResource BlueBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="13" BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0f2448" Offset="0"/>
                                    <GradientStop Color="#0d1f3c" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#3b82f6" Offset="0"/>
                                    <GradientStop Color="#6366f1" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>   <!-- Header -->
            <RowDefinition Height="42"/>   <!-- Model pills -->
            <RowDefinition Height="*"/>    <!-- Messages -->
            <RowDefinition Height="Auto"/> <!-- Input -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#040b1e"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="22,0">
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="20" Height="20" CornerRadius="5"
                                Margin="0,0,9,0" VerticalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1d4ed8" Offset="0"/>
                                    <GradientStop Color="#4f46e5" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Path Data="M8 4 C8 4 12 6 12 10 C12 14 8 16 8 16 C8 16 4 14 4 10 C4 6 8 4 8 4 Z"
                                  Fill="White" Width="9" Height="9" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Chat" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Ask anything — get clear, accurate answers"
                               FontSize="10.5" Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="29,2,0,0"/>
                </StackPanel>

                <!-- Session info badge -->
                <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                        CornerRadius="6" Background="#0d1f3c"
                        BorderBrush="#1e3a5f" BorderThickness="1" Padding="10,4">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="5" Height="5" Fill="{StaticResource GreenBrush}"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="ChatCreditsLabel" Text="Ready"
                                   FontSize="9.5" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ MODEL PILLS ═══ -->
        <Border Grid.Row="1" Background="#030912"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="18,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="PillSonnet" Style="{StaticResource ModelPillActive}"
                        Click="Pill_Click" Tag="sonnet" Margin="0,0,6,0">
                    <TextBlock Text="Sonnet 4.5" FontSize="10.5"/>
                </Button>
                <Button x:Name="PillOpus" Style="{StaticResource ModelPill}"
                        Click="Pill_Click" Tag="opus" Margin="0,0,6,0">
                    <TextBlock Text="Opus 4" FontSize="10.5"/>
                </Button>
                <Button x:Name="PillHaiku" Style="{StaticResource ModelPill}"
                        Click="Pill_Click" Tag="haiku" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Haiku 3.5" FontSize="10.5"/>
                        <TextBlock Text=" ⚡" FontSize="9.5" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="PillGemini" Style="{StaticResource ModelPill}"
                        Click="Pill_Click" Tag="gemini">
                    <TextBlock Text="Gemini Flash" FontSize="10.5"/>
                </Button>
                <TextBlock x:Name="StreamingLabel" Text=""
                           FontSize="9.5" Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center" Margin="14,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- ═══ MESSAGES ═══ -->
        <ScrollViewer Grid.Row="2" x:Name="MessagesScroll"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="22,16,6,8">
            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBar}"/>
            </ScrollViewer.Resources>
            <StackPanel x:Name="MessagesPanel" Margin="0,0,12,0">

                <!-- Welcome message -->
                <Grid x:Name="WelcomeMsg" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8" VerticalAlignment="Top">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#3b82f6" Offset="0"/>
                                <GradientStop Color="#6366f1" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="T" FontSize="13" FontWeight="Black"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Grid.Column="2"
                            Background="{StaticResource BgCardBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="4,12,12,12" Padding="14,10">
                        <StackPanel>
                            <TextBlock Text="Hello! I'm Thalamus AI."
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12.5"
                                       Foreground="{StaticResource TextSecondaryBrush}" LineHeight="19">
                                I can help with anything — questions, writing, planning, code, or just conversation. What would you like to do?
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Typing indicator (hidden by default) -->
                <Grid x:Name="TypingRow" Visibility="Collapsed" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8" VerticalAlignment="Top">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#3b82f6" Offset="0"/>
                                <GradientStop Color="#6366f1" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="T" FontSize="13" FontWeight="Black"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Grid.Column="2"
                            Background="{StaticResource BgCardBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="4,12,12,12" Padding="14,12"
                            HorizontalAlignment="Left" Width="70">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="TDot1" Width="6" Height="6" Fill="{StaticResource TextMutedBrush}" Margin="0,0,4,0">
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="0.3" To="1" Duration="0:0:0.5"
                                                                 AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <Ellipse x:Name="TDot2" Width="6" Height="6" Fill="{StaticResource TextMutedBrush}" Margin="0,0,4,0" Opacity="0.3">
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.17">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="0.3" To="1" Duration="0:0:0.5"
                                                                 AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <Ellipse x:Name="TDot3" Width="6" Height="6" Fill="{StaticResource TextMutedBrush}" Opacity="0.3">
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.34">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="0.3" To="1" Duration="0:0:0.5"
                                                                 AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                        </StackPanel>
                    </Border>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══ INPUT AREA ═══ -->
        <Border Grid.Row="3" Background="#030912"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="20,12,20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <TextBox x:Name="ChatInputBox"
                             Style="{StaticResource ThemedInput}"
                             Height="40"
                             KeyDown="ChatInput_KeyDown"/>
                    <TextBlock Text="Ask anything…"
                               IsHitTestVisible="False"
                               FontSize="13" Foreground="#253858"
                               Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=ChatInputBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Button Grid.Column="2" x:Name="SendButton"
                        Style="{StaticResource SendBtn}" Click="Send_Click">
                    <Path Data="M22 2L11 13 M22 2L15 22 9 13 2 9 22 2"
                          Stroke="White" StrokeThickness="1.7"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Width="15" Height="15" Stretch="Uniform"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
