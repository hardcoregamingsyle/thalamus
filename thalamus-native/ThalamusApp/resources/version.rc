// Thalamus AI - Windows Version Resource
// Embedded in Thalamus.exe for file properties

#include <windows.h>

VS_VERSION_INFO VERSIONINFO
FILEVERSION     1,0,0,0
PRODUCTVERSION  1,0,0,0
FILEFLAGSMASK   0x3fL
FILEFLAGS       0x0L
FILEOS          VOS_NT_WINDOWS32
FILETYPE        VFT_APP
FILESUBTYPE     VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      "Thalamus AI"
            VALUE "FileDescription",  "Thalamus AI - Native Windows Desktop Client"
            VALUE "FileVersion",      "1.0.0.0"
            VALUE "InternalName",     "Thalamus"
            VALUE "LegalCopyright",   "Copyright (C) Thalamus AI. All rights reserved."
            VALUE "OriginalFilename", "Thalamus.exe"
            VALUE "ProductName",      "Thalamus AI"
            VALUE "ProductVersion",   "1.0.0.0"
            VALUE "Comments",         "Built with Qt 6 C++. No Electron. No regrets."
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
