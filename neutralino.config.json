{
  "$schema": "https://raw.githubusercontent.com/neutralinojs/neutralinojs/main/schemas/neutralino.config.schema.json",
  "applicationId": "com.aphantic.thalamus",
  "version": "1.0.0",
  "defaultMode": "window",
  "port": 0,
  "documentRoot": "/dist/",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "one-time",
  "logging": {
    "enabled": true,
    "writeToLogFile": true
  },
  "nativeAllowList": [
    "app.*",
    "os.*",
    "window.*",
    "debug.log",
    "filesystem.readFile",
    "filesystem.writeFile",
    "filesystem.createDirectory",
    "filesystem.readDirectory"
  ],
  "modes": {
    "window": {
      "title": "Thalamus AI",
      "width": 1400,
      "height": 900,
      "minWidth": 900,
      "minHeight": 600,
      "center": true,
      "fullScreen": false,
      "alwaysOnTop": false,
      "icon": "/dist/assets/Untitled_design.png",
      "enableInspector": false,
      "borderless": true,
      "maximize": true,
      "hidden": false,
      "resizable": true,
      "exitProcessOnClose": true
    }
  },
  "cli": {
    "binaryName": "Thalamus",
    "resourcesPath": "/dist/",
    "extensionsPath": "/extensions/",
    "clientLibrary": "/dist/neutralino.js",
    "binaryVersion": "6.8.0",
    "clientVersion": "6.8.0"
  }
}
